#cal-v49 .di-col.col-proceso { border-top: 3px solid #7c3aed; }
#cal-v49 .di-col.col-revision { border-top: 3px solid #ea580c; }
#cal-v49 .di-col.col-confirmado { border-top: 3px solid #16a34a; }

#cal-v49 .di-card {
