      display: flex;
      flex-direction: column;
      height: 420px;
      overflow: hidden;
      gap: 10px;
    }
#cal-v49 .el-kpi-row {
      flex: 0 0 auto;
      display: grid;
      grid-template-columns: repeat(4,1fr);
      gap: 8px;
    }
#cal-v49 .el-kpi {
      background: white;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      text-align: center;
    }
#cal-v49 .el-kpi-num { font-size: 22px; font-weight: 800; color: #6366f1; font-family: 'DM Mono', monospace; }
#cal-v49 .el-kpi-label { font-size: 10px; color: var(--text-3); margin-top: 2px; font-weight: 600; }
#cal-v49 .el-table-wrap {
