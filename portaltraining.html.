      : 'Nunca';
    return `<tr style="${!u.activo?'opacity:.55':''}">
      <td>
        <div style="display:flex;align-items:center;gap:10px">
          <div class="user-row-avatar" style="background:${u.color}">${u.iniciales}</div>
          <div>
            <div class="td-main">${u.nombre} ${isSelf?'<span class="badge badge-gold" style="font-size:9px">Tú</span>':''}</div>
            <div class="td-soft">${u.trainer ? '🎓 Trainer: '+u.trainer : ''}</div>
