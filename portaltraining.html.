      <td class="td-mono">${u.username}</td>
      <td><span class="badge ${ROL_BADGE[u.rol]||'badge-gray'}">${ROL_LABEL[u.rol]||u.rol}</span></td>
      <td class="td-soft">${u.trainer || '—'}</td>
