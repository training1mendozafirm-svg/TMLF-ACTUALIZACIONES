#cal-v49 .el-status.en-revision { background: #dbeafe; color: #1e40af; }
#cal-v49 .el-status.completado { background: #d1fae5; color: #065f46; }
#cal-v49 .el-status.cancelado { background: #fee2e2; color: #991b1b; }
#cal-v49 .el-link-btn {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 4px 10px; border-radius: 6px; font-size: 11.5px;
      font-weight: 600; background: #eef2ff; color: #6366f1;
      text-decoration: none; border: 1px solid #c7d2fe;
      transition: all .15s;
    }
#cal-v49 .el-link-btn:hover { background: #e0e7ff; }
#cal-v49 .el-actions { display: flex; gap: 6px; }
#cal-v49 .el-btn-icon {
      padding: 5px 8px; border: 1px solid var(--border);
      border-radius: 6px; background: white; cursor: pointer;
      font-size: 13px; transition: all .15s; line-height: 1;
    }
#cal-v49 .el-btn-icon:hover { background: var(--bg-2); }
#cal-v49 .el-btn-icon.danger:hover { background: #fee2e2; border-color: #fca5a5; }
#cal-v49 .el-empty {
      text-align: center; padding: 48px 20px;
