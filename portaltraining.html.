function toggleOffTrainer() {
  const isOne = document.getElementById('off-scope-one').checked;
  document.getElementById('sp-off-trainer-wrap').style.display = isOne ? '' : 'none';
}

function saveSpecial() {
  const trainer = document.getElementById('sp-trainer').value;
  if (!trainer && specialTabActivo !== 'off') { calV49ShowToast('⚠️ Selecciona un trainer', 'warn'); return; }

  let ev;
  if (specialTabActivo === 'vac') {
    const s = document.getElementById('sp-vac-start').value;
    const e = document.getElementById('sp-vac-end').value;
    const nota = document.getElementById('sp-vac-nota').value.trim();
    if (!s || !e) { calV49ShowToast('⚠️ Ingresa fechas de inicio y fin', 'warn'); return; }
    if (e < s)    { calV49ShowToast('⚠️ La fecha fin debe ser después del inicio', 'warn'); return; }
    ev = {
      id: calV49GenId(), title: '🏖️ Vacaciones – ' + trainer,
      trainer, tipoActividad: 'Vacaciones',
      modalidad: '', sala: '', area: '',
      descripcion: nota || '',
      prioridad: '', estatus: '',
      start: s, end: e
    };
  } else if (specialTabActivo === 'bday') {
    const fecha = document.getElementById('sp-bday-fecha').value;
    if (!fecha) { calV49ShowToast('⚠️ Ingresa la fecha de cumpleaños', 'warn'); return; }
    ev = {
      id: calV49GenId(), title: '🎂 Cumpleaños – ' + trainer,
      trainer, tipoActividad: 'Cumpleaños',
      modalidad: '', sala: '', area: '',
      descripcion: '',
      prioridad: '', estatus: '',
      start: fecha, end: fecha
    };
  } else if (specialTabActivo === 'off') {
    const s = document.getElementById('sp-off-start').value;
    const e = document.getElementById('sp-off-end').value;
    const motivo = document.getElementById('sp-off-motivo').value.trim();
    const isOne  = document.getElementById('off-scope-one').checked;
    const offTrainer = isOne ? document.getElementById('sp-off-trainer').value : 'Equipo';
    if (!s)      { calV49ShowToast('⚠️ Ingresa la fecha de inicio', 'warn'); return; }
    if (!motivo) { calV49ShowToast('⚠️ Ingresa el motivo del día OFF', 'warn'); return; }
    if (isOne && !offTrainer) { calV49ShowToast('⚠️ Selecciona el trainer', 'warn'); return; }
    ev = {
      id: calV49GenId(),
      title: '🚫 ' + motivo + (isOne ? ' – ' + offTrainer : ''),
      trainer: offTrainer,
      tipoActividad: 'Día OFF',
      modalidad: '', sala: '', area: '',
      descripcion: motivo,
      prioridad: '', estatus: '',
      start: s,
      end: (e && e !== s) ? e : s
    };
  }

  if (!ev) return;
  if (specialEditingId) {
    ev.id = specialEditingId;
    const idx = cal49Eventos.findIndex(e => e.id === specialEditingId);
    if (idx > -1) cal49Eventos[idx] = ev;
    cal49ApiPost({ action: 'update', evento: ev });
    calV49ShowToast('✅ Actualizado correctamente', 'success');
  } else {
    cal49Eventos.push(ev);
    cal49ApiPost({ action: 'create', evento: ev });
    calV49ShowToast('✅ Registrado correctamente', 'success');
  }
  specialEditingId = null;
  calV49CloseModal('specialModal');
  cal49RefreshCalendar();
}

// ── Sidebar: vacaciones & cumpleaños ─────────────────────────
function updateVacaciones() {
  const hoy = new Date();
  hoy.setHours(0,0,0,0);
  const en30 = new Date(hoy.getTime() + 30 * 86400000);

  const hace7 = new Date(hoy.getTime() - 7 * 86400000);
  const vacs = cal49Eventos
    .filter(ev => ev.tipoActividad === 'Vacaciones')
    .filter(ev => {
      const fin = new Date((ev.end || ev.start) + 'T23:59:59');
      const ini = calV49ParseLocal(ev.start);
      return fin >= hace7; // futuras, en curso, o terminadas hace menos de 7 días
    })
    .sort((a,b) => new Date(a.start) - new Date(b.start))
    .slice(0, 6);

  const list = document.getElementById('vacList');
  if (!vacs.length) {
    list.innerHTML = '<div style="font-size:12px;color:var(--text-3);padding:4px">Sin vacaciones próximas.</div>';
    return;
  }

  list.innerHTML = vacs.map(ev => {
    const ini = calV49ParseLocal(ev.start);
    const fin = calV49ParseLocal(ev.end || ev.start);
    const enCurso = ini <= hoy && fin >= hoy;
    const fmtD = d => d.toLocaleDateString('es-MX', { day:'numeric', month:'short' });
    const rango = ev.start === ev.end ? fmtD(ini) : fmtD(ini) + ' – ' + fmtD(fin);
    const color = cal49TrainerColor(ev.trainer);
    return `<div class="vac-item${enCurso ? ' hoy' : ''}" style="cursor:pointer" onclick="cal49OpenDetailById('${ev.id}')">
      <div class="vac-icon">🏖️</div>
      <div style="flex:1;min-width:0">
        <div class="vac-name" style="color:${color}">${ev.trainer}</div>
        <div class="vac-dates">${rango}${ev.descripcion ? ' · ' + ev.descripcion : ''}</div>
      </div>
      ${enCurso ? '<span style="font-size:10px;background:#f59e0b;color:#fff;padding:2px 6px;border-radius:10px;font-weight:700">HOY</span>' : ''}
    </div>`;
  }).join('');
}

function updateCumpleanos() {
  const hoy = new Date();
  hoy.setHours(0,0,0,0);

  // Obtener cumpleaños y calcular próxima ocurrencia este año
  const bdays = cal49Eventos
    .filter(ev => ev.tipoActividad === 'Cumpleaños')
    .map(ev => {
      const orig = calV49ParseLocal(ev.start);
      // Próxima ocurrencia: este año o el siguiente
      let proxima = new Date(hoy.getFullYear(), orig.getMonth(), orig.getDate());
      if (proxima < hoy) proxima.setFullYear(proxima.getFullYear() + 1);
      const diasFaltan = Math.round((proxima - hoy) / 86400000);
      return { ...ev, proxima, diasFaltan };
    })
    .sort((a,b) => a.diasFaltan - b.diasFaltan)
    .slice(0, 6);

  const list = document.getElementById('bdayList');
  if (!bdays.length) {
    list.innerHTML = '<div style="font-size:12px;color:var(--text-3);padding:4px">Sin cumpleaños registrados.</div>';
    return;
  }

  list.innerHTML = bdays.map(ev => {
    const pronto = ev.diasFaltan <= 7;
    const hoyBday = ev.diasFaltan === 0;
    const label = hoyBday ? '🎉 HOY' : (ev.diasFaltan === 1 ? 'mañana' : 'en ' + ev.diasFaltan + ' días');
    const color = cal49TrainerColor(ev.trainer);
    const fmtFecha = ev.proxima.toLocaleDateString('es-MX', { day:'numeric', month:'long' });
    return `<div class="bday-item${pronto ? ' pronto' : ''}">
      <div class="bday-days" style="background:${hoyBday?'#ec4899':'#fdf2f8'};color:${hoyBday?'#fff':'#9d174d'}">${label}</div>
      <div style="flex:1;min-width:0">
        <div class="bday-name" style="color:${color}">${ev.trainer}</div>
        <div class="bday-fecha">${fmtFecha}</div>
      </div>
      <div style="font-size:18px">🎂</div>
    </div>`;
  }).join('');
}

