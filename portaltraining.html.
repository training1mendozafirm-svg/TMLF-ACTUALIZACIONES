    /* =========================================================
#cal-v49 MODAL BASE
#cal-v49 ========================================================= */
#cal-v49 .modal-overlay {
      position: fixed; inset: 0; background: rgba(15,22,35,.55);
      z-index: 1000; display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity .2s;
      backdrop-filter: blur(2px);
    }
#cal-v49 .modal-overlay.open { opacity: 1; pointer-events: all; }
#cal-v49 .modal {
      background: var(--surface); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg); width: 100%; max-height: 90vh;
      overflow-y: auto; transform: translateY(12px) scale(.97);
      transition: transform .22s, opacity .22s; opacity: 0;
    }
#cal-v49 .modal-overlay.open .modal { transform: none; opacity: 1; }

#cal-v49 .modal-header {
      padding: 20px 24px 16px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 12px;
    }
#cal-v49 .modal-header-icon {
      width: 38px; height: 38px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
#cal-v49 .modal-title { font-size: 16px; font-weight: 700; color: var(--text-1); }
#cal-v49 .modal-subtitle { font-size: 12.5px; color: var(--text-3); margin-top: 1px; }
#cal-v49 .modal-close {
      margin-left: auto; background: none; border: none; cursor: pointer;
      color: var(--text-3); padding: 4px; border-radius: 6px;
      font-size: 20px; line-height: 1; transition: all .15s;
    }
#cal-v49 .modal-close:hover { background: var(--surface2); color: var(--text-1); }
#cal-v49 .modal-body { padding: 20px 24px; }
#cal-v49 .modal-footer {
      padding: 16px 24px; border-top: 1px solid var(--border);
      display: flex; gap: 10px; justify-content: flex-end;
    }

    /* =========================================================
#cal-v49 FORM MODAL
#cal-v49 ========================================================= */
#cal-v49 #formModal .modal { max-width: 620px; }
#cal-v49 .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
#cal-v49 .form-row.full { grid-template-columns: 1fr; }
#cal-v49 .form-row.thirds { grid-template-columns: 1fr 1fr 1fr; }
#cal-v49 .form-group { display: flex; flex-direction: column; gap: 5px; }
#cal-v49 .form-label {
      font-size: 12px; font-weight: 600; color: var(--text-2);
      text-transform: uppercase; letter-spacing: .5px;
    }
#cal-v49 .form-control {
      padding: 9px 12px; border: 1px solid var(--border-md);
      border-radius: 8px; font-family: inherit; font-size: 14px;
      color: var(--text-1); background: var(--surface2);
      transition: border-color .15s, box-shadow .15s;
    }
#cal-v49 .form-control:focus {
      outline: none; border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(28,78,216,.12);
    }
#cal-v49 textarea.form-control { resize: vertical; min-height: 72px; }
#cal-v49 .form-section-title {
      font-size: 11px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: var(--text-3);
      border-bottom: 1px solid var(--border); padding-bottom: 8px;
      margin-bottom: 14px; margin-top: 6px;
    }

    /* Priority pills select */
#cal-v49 .priority-group { display: flex; gap: 8px; flex-wrap: wrap; }
#cal-v49 .priority-pill {
      padding: 5px 12px; border-radius: 20px; border: 1.5px solid var(--border-md);
      font-size: 12px; font-weight: 600; cursor: pointer;
      background: var(--surface2); color: var(--text-3);
      transition: all .15s;
    }
#cal-v49 .priority-pill.selected-alta { background: #fef2f2; border-color: #fca5a5; color: var(--danger); }
#cal-v49 .priority-pill.selected-media { background: #fefce8; border-color: #fcd34d; color: #a16207; }
#cal-v49 .priority-pill.selected-baja { background: #f0fdf4; border-color: #16a34a; color: #16a34a; }

    /* =========================================================
#cal-v49 DETAIL MODAL
#cal-v49 ========================================================= */
#cal-v49 #detailModal .modal { max-width: 520px; }

#cal-v49 .detail-trainer-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 700;
      color: #fff; margin-bottom: 16px;
    }
#cal-v49 .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
#cal-v49 .detail-field { display: flex; flex-direction: column; gap: 3px; }
#cal-v49 .detail-field-label {
      font-size: 10.5px; font-weight: 700; letter-spacing: .8px;
      text-transform: uppercase; color: var(--text-3);
    }
#cal-v49 .detail-field-value { font-size: 14px; font-weight: 500; color: var(--text-1); }
#cal-v49 .detail-desc {
      margin-top: 14px; padding: 12px; background: var(--surface2);
      border-radius: 8px; border: 1px solid var(--border);
      font-size: 13.5px; color: var(--text-2); line-height: 1.6;
    }
#cal-v49 .status-badge {
      display: inline-block; padding: 3px 10px; border-radius: 12px;
      font-size: 11.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
    }
#cal-v49 .status-planeado { background: #eff3ff; color: var(--accent); }
#cal-v49 .status-confirmado { background: #f0fdf4; color: var(--success); }
#cal-v49 .status-en-curso { background: #fffbeb; color: var(--warning); }
#cal-v49 .status-completado { background: #e5e7eb; color: #374151; }
#cal-v49 .status-cancelado { background: #fef2f2; color: var(--danger); }
#cal-v49 .priority-badge {
      display: inline-block; padding: 3px 10px; border-radius: 12px;
      font-size: 11.5px; font-weight: 700;
    }
#cal-v49 .priority-alta { background:#fef2f2; color:#dc2626; border:1px solid #fca5a5; }
#cal-v49 .priority-media { background:#fefce8; color:#a16207; border:1px solid #fcd34d; }
#cal-v49 .priority-baja { background:#f0fdf4; color:#16a34a; border:1px solid #86efac; }

    /* =========================================================
#cal-v49 TOAST
#cal-v49 ========================================================= */
#cal-v49 .toast-container {
      position: fixed; bottom: 24px; right: 24px; z-index: 2000;
      display: flex; flex-direction: column; gap: 8px;
    }
#cal-v49 .toast {
      background: var(--text-1); color: #fff;
      padding: 12px 18px; border-radius: 10px;
      font-size: 13.5px; font-weight: 500;
      box-shadow: var(--shadow-lg); max-width: 300px;
      animation: toastIn .25s ease; display: flex; align-items: center; gap: 8px;
    }
    @keyframes toastIn {
      from { transform: translateY(16px); opacity: 0; }
      to { transform: none; opacity: 1; }
    }

    /* =========================================================
#cal-v49 RESPONSIVE
#cal-v49 ========================================================= */
    @media (max-width: 900px) {
  #cal-v49, #cal-v49 { overflow: auto; height: auto; }
  #cal-v49 .layout { grid-template-columns: 1fr; height: auto; overflow: visible; }
  #cal-v49 .sidebar { border-right: none; border-bottom: 1px solid var(--border); padding: 16px; flex-direction: row; flex-wrap: wrap; overflow: visible; height: auto; }
  #cal-v49 .sidebar > div { flex: 1 1 180px; min-width: 0; border-bottom: none; padding-bottom: 0; }
  #cal-v49 .kpi-grid { grid-template-columns: repeat(4, 1fr); }
  #cal-v49 .form-row.thirds { grid-template-columns: 1fr 1fr; }
  #cal-v49 .main { overflow: visible; height: auto; }
    }
    @media (max-width: 600px) {
  #cal-v49 .form-row { grid-template-columns: 1fr; }
  #cal-v49 .form-row.thirds { grid-template-columns: 1fr; }
  #cal-v49 .topbar-sub { display: none; }
  #cal-v49 .kpi-grid { grid-template-columns: 1fr 1fr; }
    }

    /* =========================================================
#cal-v49 PRIORIDAD VISUAL EN BLOQUES DE EVENTOS
#cal-v49 ========================================================= */
#cal-v49 .ev-priority-stripe {
      position: absolute; left: 0; top: 0; bottom: 0;
