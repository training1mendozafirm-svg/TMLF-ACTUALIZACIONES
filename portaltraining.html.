    if (fTrainer && s.trainer !== fTrainer) return false;
    if (fEstatus && s.estatus !== fEstatus) return false;
    if (fBuscar && !((s.title||'') + (s.notas||'') + (s.plataforma||'')).toLowerCase().includes(fBuscar)) return false;
    return true;
  }).sort((a,b) => (a.start||'').localeCompare(b.start||''));

