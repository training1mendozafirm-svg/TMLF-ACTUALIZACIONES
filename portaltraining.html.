function saveElSesion() {
  const titulo    = document.getElementById('el-form-titulo').value.trim();
  const trainer   = document.getElementById('el-form-trainer').value;
  const estatus   = document.getElementById('el-form-estatus').value;
  const fecha     = document.getElementById('el-form-fecha').value;
  const horaIni   = document.getElementById('el-form-hora-ini').value;
  const horaFin   = document.getElementById('el-form-hora-fin').value;
  const plataforma= document.getElementById('el-form-plataforma').value.trim();
  let   link      = document.getElementById('el-form-link').value.trim();
  const notas     = document.getElementById('el-form-notas').value.trim();

  if (!titulo || !trainer || !fecha) {
    calV49ShowToast('⚠️ Completa los campos obligatorios', 'warn'); return;
  }
  if (link && !link.startsWith('http')) link = 'https://' + link;

  const start = fecha + (horaIni ? 'T' + horaIni : '');
  const end   = fecha + (horaFin ? 'T' + horaFin : '');

  const sesion = {
    id:         elEditingId || calV49GenId(),
    title:      titulo,
    trainer,
    estatus,
    plataforma,
    link,
    notas,
    start,
    end: horaFin ? end : start
  };

  if (elEditingId) {
    const idx = elSesiones.findIndex(x => x.id === elEditingId);
    if (idx > -1) elSesiones[idx] = sesion;
    apiPostEl({ action: 'update', evento: sesion });
    calV49ShowToast('✅ Sesión actualizada', 'success');
  } else {
    elSesiones.push(sesion);
    apiPostEl({ action: 'create', evento: sesion });
    calV49ShowToast('✅ Sesión registrada', 'success');
  }

  calV49CloseModal('elModal');
  renderElTable();
  renderElCalendar();
  updateElKpis();
}

function deleteElSesion(id) {
  if (!confirm('¿Eliminar esta sesión E-Learning?')) return;
  elSesiones = elSesiones.filter(x => x.id !== id);
  apiPostEl({ action: 'delete', id });
  renderElTable();
  renderElCalendar();
  updateElKpis();
  calV49ShowToast('🗑 Sesión eliminada');
}

