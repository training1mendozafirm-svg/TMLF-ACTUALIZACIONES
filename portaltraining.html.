function cal49SaveEvento() {
  const trainer = document.getElementById('f-form-trainer').value;
  const tipo = document.getElementById('f-form-tipo').value;
  const title = document.getElementById('f-form-title').value.trim();
  const date = document.getElementById('f-form-date').value;
  const dateEnd = document.getElementById('f-form-date-end').value;
  const isAllDay = document.getElementById('f-form-allday').checked;
  const startT = document.getElementById('f-form-start').value;
  const endT = document.getElementById('f-form-end').value;

  if (!trainer || !tipo || !title || !date) {
    calV49ShowToast('⚠️ Completa los campos obligatorios', 'warn');
    return;
  }

  let startStr, endStr;
  if (isAllDay) {
    startStr = date; // solo fecha, sin hora → allDay en FC
    endStr = (dateEnd && dateEnd !== date) ? dateEnd : null;
  } else {
    startStr = date + (startT ? 'T' + startT : 'T00:00');
    if (dateEnd && dateEnd !== date) {
      endStr = dateEnd + (endT ? 'T' + endT : 'T00:00');
    } else {
      endStr = endT ? date + 'T' + endT : null;
    }
  }

  const ev = {
    id: editingId || calV49GenId(),
    title,
    trainer,
    trainer2: getTrainer2Value(),
    tipoActividad: tipo,
    modalidad: document.getElementById('f-form-modalidad').value || '—',
    sala: document.getElementById('f-form-sala').value || '—',
    area: document.getElementById('f-form-area').value || '—',
    descripcion: document.getElementById('f-form-desc').value,
    prioridad: document.getElementById('f-form-prioridad').value || 'Media',
    estatus: document.getElementById('f-form-estatus').value || 'Planeado',
    link: (() => {
      let l = document.getElementById('f-form-link').value.trim();
      if (l && !l.startsWith('http://') && !l.startsWith('https://')) l = 'https://' + l;
      return l;
    })(),
    start: startStr,
    end: endStr
  };

  if (editingId) {
    const idx = cal49Eventos.findIndex(e => e.id === editingId);
    if (idx > -1) cal49Eventos[idx] = ev;
    cal49ApiPost({ action: 'update', evento: ev }); // ← sincroniza con Google Sheets
    calV49ShowToast('✅ Actividad actualizada');
  } else {
    cal49Eventos.push(ev);
    cal49ApiPost({ action: 'create', evento: ev }); // ← sincroniza con Google Sheets
    calV49ShowToast('✅ Actividad registrada');
  }

  calV49CloseModal('formModal');
  cal49RefreshCalendar();
}

