function cal49OpenDetailById(id) {
  const ev = cal49Eventos.find(e => e.id === id);
  if (!ev) return;
  currentDetailId = id;

  const color = cal49TrainerColor(ev.trainer);
  const prio = (ev.prioridad || 'Media').toLowerCase();
  const prioIcon = prio === 'alta' ? '🔴' : prio === 'baja' ? '🟢' : '🟡';
  const prioLabel = { alta: 'PRIORIDAD ALTA — Actividad crítica', media: 'PRIORIDAD MEDIA', baja: 'PRIORIDAD BAJA' }[prio] || ev.prioridad;

  // Priority banner
  const banner = document.getElementById('d-priority-banner');
  banner.className = 'detail-priority-banner ' + prio;
  document.getElementById('d-priority-icon').textContent = prioIcon;
  document.getElementById('d-priority-text').textContent = prioLabel;

  // Duration chip
  const dur = calcDuracion(ev);
  const durChip = document.getElementById('d-duration-chip');
  durChip.textContent = dur ? '⏱ ' + dur : '📅 —';

  // Header
  document.getElementById('detailTitle').textContent = ev.title;
  document.getElementById('detailTipo').textContent = (CAL49_TIPOS_ICON[ev.tipoActividad] || '📌') + ' ' + (ev.tipoActividad || '—');
  const t2 = ev.trainer2 ? ` <span style="opacity:.8;font-size:11px">+ ${ev.trainer2}</span>` : '';
  document.getElementById('detailTrainerBadge').innerHTML = '👤 ' + ev.trainer + t2;
  document.getElementById('detailTrainerBadge').style.background = color;

  // Dates
  const isAllDay = !ev.start.includes('T');
  const start = calV49ParseLocal(ev.start);
  const end = ev.end ? calV49ParseLocal(ev.end) : null;

  document.getElementById('d-fecha').textContent = start.toLocaleDateString('es-MX',
    { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });

  if (isAllDay) {
    if (ev.end && ev.end !== ev.start) {
      // Restar 1 día para mostrar el fin real (FC usa exclusivo)
      const displayEnd = new Date(end);
      displayEnd.setDate(displayEnd.getDate() - 1);
      document.getElementById('d-horario').textContent =
        'Todo el día · hasta ' + displayEnd.toLocaleDateString('es-MX',{ month:'short', day:'numeric' });
    } else {
      document.getElementById('d-horario').textContent = 'Todo el día';
    }
  } else {
    document.getElementById('d-horario').textContent =
      start.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit', hour12: false }) +
      (end && ev.end.includes('T') ? ' – ' + end.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit', hour12: false }) : '');
  }

  document.getElementById('d-sala').textContent = ev.sala || '—';
  document.getElementById('d-modalidad').textContent = ev.modalidad || '—';
  document.getElementById('d-area').textContent = ev.area || '—';

  const cls = (ev.estatus || '').toLowerCase().replace(' ','-');
  document.getElementById('d-estatus').innerHTML = `<span class="status-badge status-${cls}">${ev.estatus || '—'}</span>`;

  const pcls = (ev.prioridad || '').toLowerCase();
  document.getElementById('d-prioridad').innerHTML = `<span class="priority-badge priority-${pcls}">${prioIcon} ${ev.prioridad || '—'}</span>`;

  document.getElementById('d-tipo-val').textContent = (CAL49_TIPOS_ICON[ev.tipoActividad] || '📌') + ' ' + (ev.tipoActividad || '—');

  const descEl = document.getElementById('d-desc');
  if (ev.descripcion) { descEl.textContent = ev.descripcion; descEl.style.display = 'block'; }
  else { descEl.style.display = 'none'; }

  // Link
  const linkWrap = document.getElementById('d-link-wrap');
  const linkEl = document.getElementById('d-link');
  const linkText = document.getElementById('d-link-text');
  if (ev.link && ev.link.trim()) {
    const rawLink = ev.link.trim();
    const fullLink = rawLink.startsWith('http') ? rawLink : 'https://' + rawLink;
    linkEl.href = fullLink;
    try {
      const domain = new URL(fullLink).hostname.replace('www.','');
      linkText.textContent = 'Abrir enlace · ' + domain;
    } catch(e) {
      linkText.textContent = rawLink.slice(0, 60) + (rawLink.length > 60 ? '…' : '');
    }
    linkWrap.style.display = 'block';
  } else {
    linkWrap.style.display = 'none';
  }

  // Link field en grid
  const linkField = document.getElementById('d-link-field');
  const linkFieldVal = document.getElementById('d-link-field-val');
  if (ev.link && ev.link.trim()) {
    const rawLink = ev.link.trim();
    const fullLink = rawLink.startsWith('http') ? rawLink : 'https://' + rawLink;
    linkFieldVal.innerHTML = `<a href="${fullLink}" target="_blank" rel="noopener" style="color:var(--accent);text-decoration:underline">${rawLink}</a>`;
    linkField.style.display = '';
  } else {
    linkField.style.display = 'none';
  }

  document.getElementById('detailIcon').textContent = CAL49_TIPOS_ICON[ev.tipoActividad] || '📋';

  calV49OpenModal('detailModal');
}

