      color: #fff !important; font-weight: 700 !important;
      font-size: 11px !important;
    }


    /* Trainer secundario */
#cal-v49 .t2-row { display: flex; flex-direction: column; gap: 8px; }
#cal-v49 .t2-manual-hidden { display: none !important; }
#cal-v49 .t2-manual-visible { display: block !important; }

    /* Modal especial vacaciones/cumpleaños */
#cal-v49 #specialModal .modal { max-width: 480px; }
#cal-v49 .special-form-tabs {
      display: flex; gap: 8px; margin-bottom: 18px;
