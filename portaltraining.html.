/* ── END DI REVIEW CSS ── */
.cal-modal-overlay {
  position:fixed; inset:0; background:rgba(15,22,35,.55);
  z-index:2000; display:flex; align-items:center; justify-content:center;
  opacity:0; pointer-events:none; transition:opacity .2s;
  backdrop-filter:blur(3px);
}
.cal-modal-overlay.open { opacity:1; pointer-events:all; }
.cal-modal-inner {
  background:#fff; border-radius:16px;
  box-shadow:0 12px 40px rgba(15,22,35,.18);
  width:100%; max-height:90vh;
  overflow-y:auto; transform:translateY(12px) scale(.97);
  transition:transform .22s, opacity .22s; opacity:0;
}
.cal-modal-overlay.open .cal-modal-inner { transform:none; opacity:1; }
.cal-modal-header {
  padding:18px 22px 14px; border-bottom:1px solid #e4e8f0;
  display:flex; align-items:center; gap:12px;
}
.cal-modal-icon {
  width:38px; height:38px; border-radius:10px;
  display:flex; align-items:center; justify-content:center;
  font-size:18px; flex-shrink:0;
}
.cal-modal-title { font-size:15px; font-weight:700; color:#0f1623; }
.cal-modal-sub   { font-size:12px; color:#7b8aab; margin-top:1px; }
.cal-modal-close {
  margin-left:auto; background:none; border:none; cursor:pointer;
  color:#7b8aab; padding:4px; border-radius:6px;
  font-size:20px; line-height:1; transition:all .15s;
}
.cal-modal-close:hover { background:#f8f9fc; color:#0f1623; }
.cal-modal-body   { padding:18px 22px; }
.cal-modal-footer {
  padding:14px 22px; border-top:1px solid #e4e8f0;
  display:flex; gap:10px; justify-content:flex-end;
}
.cal-form-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
.cal-form-row.full { grid-template-columns:1fr; }
.cal-form-row.thirds { grid-template-columns:1fr 1fr 1fr; }
.cal-form-group { display:flex; flex-direction:column; gap:5px; }
.cal-form-label { font-size:11px; font-weight:600; color:#3d4b63; text-transform:uppercase; letter-spacing:.5px; }
.cal-form-ctrl {
  padding:9px 11px; border:1px solid #d0d6e4;
  border-radius:8px; font-family:inherit; font-size:13.5px;
  color:#0f1623; background:#f8f9fc; transition:border-color .15s, box-shadow .15s;
}
.cal-form-ctrl:focus { outline:none; border-color:#1c4ed8; box-shadow:0 0 0 3px rgba(28,78,216,.12); }
textarea.cal-form-ctrl { resize:vertical; min-height:68px; }
.cal-form-sec-title {
  font-size:11px; font-weight:700; text-transform:uppercase;
  letter-spacing:1px; color:#7b8aab; margin:14px 0 8px;
}
.cal-time-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
.cal-allday-row { display:flex; align-items:center; gap:8px; margin-bottom:10px; font-size:13px; color:#3d4b63; }
.cal-allday-row input[type=checkbox] { width:15px; height:15px; accent-color:#1c4ed8; }
/* detail modal */
.cal-detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:14px; }
.cal-detail-field { display:flex; flex-direction:column; gap:3px; }
.cal-detail-label { font-size:10.5px; font-weight:600; text-transform:uppercase; letter-spacing:.5px; color:#7b8aab; }
.cal-detail-val   { font-size:13.5px; color:#0f1623; font-weight:500; }
.cal-detail-desc  { background:#f8f9fc; border-radius:8px; padding:12px; font-size:13px; color:#3d4b63; line-height:1.55; border:1px solid #e4e8f0; }
/* special modal tabs */
.cal-special-tabs { display:flex; gap:8px; margin-bottom:16px; }
.cal-special-tab {
  flex:1; padding:10px; border-radius:8px; border:2px solid #e4e8f0;
  background:#f8f9fc; cursor:pointer; font-family:inherit;
  font-size:13px; font-weight:600; color:#3d4b63;
