#cal-v49 .fc-daygrid-day-number { color: var(--text-2) !important; font-size: 13px !important; font-weight: 500; }
#cal-v49 .fc-timegrid-slot-label { font-size: 11px !important; color: var(--text-3); }
#cal-v49 .fc-toolbar { margin-bottom: 16px !important; }
#cal-v49 .calendar-card {
