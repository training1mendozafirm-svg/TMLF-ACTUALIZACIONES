}

function saveNuevaRevision() {
  const session = getSession();
  const titulo  = document.getElementById('nrev-titulo')?.value.trim();
  const area    = document.getElementById('nrev-area')?.value;
  const tipo    = document.getElementById('nrev-tipo')?.value;
  const link    = document.getElementById('nrev-link-material')?.value.trim();

  if (!titulo) { showToast('⚠️ El título es obligatorio','error'); return; }
  if (!area)   { showToast('⚠️ Selecciona el área','error'); return; }
  if (!tipo)   { showToast('⚠️ Selecciona el tipo de material','error'); return; }
  if (!link)   { showToast('⚠️ El link al material es obligatorio','error'); return; }

  const revs = getRevisiones();
  const id   = 'REV-' + String(revs.length + 1).padStart(3,'0') + '-' + Date.now().toString(36).toUpperCase();
  const fecha= new Date().toISOString().slice(0,10);
  const rev  = {
    id, titulo, area,
    tipoMaterial:           tipo,
    prioridad:              document.getElementById('nrev-prioridad')?.value || 'Media',
    linkMaterial:           link,
    linkInstrumento:        document.getElementById('nrev-link-instrumento')?.value.trim() || '',
    descripcion:            document.getElementById('nrev-descripcion')?.value.trim() || '',
    solicitanteNombre:      session.nombre,
    solicitanteUsername:    session.username,
    trainerCal:             session.trainer || null,
    revisora:               null,
    estatus:                'Nueva',
    fechaSolicitud:         fecha,
    comentariosRevisora:    '',
    comentariosTrainer:     '',
    historial: [{ quien: session.nombre, accion:'Petición registrada', fecha }]
  };
  revs.push(rev);
  saveRevisiones(revs);
  showToast('✅ Petición enviada correctamente','success');
  closeModal();
  renderRevisiones();
}

/* ── ACCIONES REVISORA ── */
function revTomarRevision(id) {
  const session = getSession();
  const revs    = getRevisiones();
  const r       = revs.find(x=>x.id===id);
  if (!r) return;
  r.estatus  = 'En revisión';
  r.revisora = session.nombre;
  r.historial.push({ quien:session.nombre, accion:'Tomó la revisión', fecha:new Date().toISOString().slice(0,10) });
  saveRevisiones(revs);
  showToast('📋 Tomaste la revisión de: ' + r.titulo,'success');
  renderRevisiones();
}

function revDarObservaciones(id) {
  const r = getRevisiones().find(x=>x.id===id);
  if (!r) return;
  showModal(`
    <div class="modal-header">
      <div><div class="modal-title">Observaciones para el trainer</div><div class="modal-sub">${r.titulo}</div></div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      ${r.linkMaterial ? `<div style="margin-bottom:14px"><a href="${r.linkMaterial}" target="_blank" class="rev-link-pill">↗ Ver material del trainer</a></div>` : ''}
      <div class="form-group">
        <label class="form-label">Observaciones / Cambios solicitados *</label>
        <textarea class="form-control" id="obs-texto" rows="5"
          placeholder="Describe qué debe modificar el trainer antes de aprobar…">${r.comentariosRevisora||''}</textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="filter-btn" onclick="closeModal()">Cancelar</button>
      <button class="filter-btn" style="background:var(--warn);color:white;border:none" onclick="saveObservaciones('${id}')">📝 Enviar observaciones</button>
    </div>
  `);
}

function saveObservaciones(id) {
  const session = getSession();
  const texto   = document.getElementById('obs-texto')?.value.trim();
  if (!texto) { showToast('⚠️ Escribe las observaciones','error'); return; }
  const revs = getRevisiones();
  const r    = revs.find(x=>x.id===id);
  if (!r) return;
  r.estatus             = 'Con observaciones';
  r.comentariosRevisora = texto;
  r.historial.push({ quien:session.nombre, accion:'Enviaron observaciones', fecha:new Date().toISOString().slice(0,10) });
  saveRevisiones(revs);
  showToast('📝 Observaciones enviadas al trainer','success');
  closeModal();
  renderRevisiones();
}

function revAprobar(id) {
  const session = getSession();
  const revs    = getRevisiones();
  const r       = revs.find(x=>x.id===id);
  if (!r) return;
  if (!confirm(`¿Aprobar el material "${r.titulo}"?`)) return;
  r.estatus = 'Aprobada';
  r.historial.push({ quien:session.nombre, accion:'Material aprobado ✅', fecha:new Date().toISOString().slice(0,10) });
  saveRevisiones(revs);
