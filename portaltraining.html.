function resetUserPassword(id) {
  const users = getUsers() || [];
  const u = users.find(x=>x.id===id);
  if (!u) return;
  if (!confirm(`¿Resetear contraseña de ${u.nombre}?\nLa nueva contraseña temporal será: tmlf2025`)) return;
  u.password = TEMP_PASS;
  saveUsers(users);
  showToast(`🔑 Contraseña reseteada para ${u.nombre}. Temp: tmlf2025`, 'success');
  renderUsuarios();
}

function deleteUserConfirm(id) {
  const users = getUsers() || [];
  const u = users.find(x=>x.id===id);
  if (!u) return;
  if (!confirm(`¿Eliminar permanentemente el usuario "${u.nombre}" (${u.username})?\nEsta acción no se puede deshacer.`)) return;
  saveUsers(users.filter(x=>x.id!==id));
