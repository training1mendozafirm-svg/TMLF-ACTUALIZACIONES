<!-- ============================================================
     LOGIN SCREEN
     ============================================================ -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">TMLF <span>Training</span></div>
    <div class="login-portal-tag">Training Center · Portal Operativo</div>
    <div class="login-card">
      <div class="login-card-title">Acceder al portal</div>
      <div class="login-card-sub">Ingresa tus credenciales para continuar</div>
      <label class="login-label">Usuario</label>
      <input class="login-input" type="text" id="login-username" placeholder="tu.usuario" autocomplete="username"
             onkeydown="if(event.key==='Enter')doLogin()">
      <label class="login-label">Contraseña</label>
      <input class="login-input" type="password" id="login-password" placeholder="••••••••" autocomplete="current-password"
             onkeydown="if(event.key==='Enter')doLogin()">
      <button class="login-btn" onclick="doLogin()">Iniciar sesión →</button>
      <div id="login-error"   class="login-error hidden">Usuario o contraseña incorrectos.</div>
      <div id="login-inactive" class="login-inactive hidden">Tu acceso está desactivado. Contacta al administrador.</div>
    </div>
    <div class="login-footer">TMLF Training Center · Acceso restringido</div>
  </div>
</div>

<!-- ============================================================
     LOADER
     ============================================================ -->
<div id="loader">
