.section-divider { height:1px; background:var(--beige-dark); margin:28px 0; }
.empty-state { text-align:center; padding:48px 24px; color:var(--text-soft); font-size:13px; }
.empty-state-icon { font-size:40px; margin-bottom:12px; }
