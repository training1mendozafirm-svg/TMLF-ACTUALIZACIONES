  r.historial.push({ quien:session.nombre, accion:'Modificaciones enviadas para re-revisión', fecha:new Date().toISOString().slice(0,10) });
  saveRevisiones(revs);
  showToast('📨 Modificaciones enviadas a la revisora','success');
  renderRevisiones();
}

