   REVISORAS: Brenda (username: brenda) + Karen Reyna (karen.reyna)
     → Ven todas las peticiones
     → Toman revisión, dan feedback/observaciones, aprueban
     → Marcan "Lista para subir" y "Completada"

   TRAINERS (resto):
     → Crean nueva petición de revisión
     → Ven solo sus propias peticiones
     → Actualizan avance + links de material e instrumento
     → Marcan "Modificaciones enviadas"

   MANAGER / ADMIN / COORDINADORA:
     → Vista de lectura general de todas las peticiones
   ============================================================ */

/* ── STORAGE ── */
function getRevisiones() {
  try { return JSON.parse(localStorage.getItem('tmlf_revisiones')) || []; } catch(e){ return []; }
}
function saveRevisiones(data) {
  localStorage.setItem('tmlf_revisiones', JSON.stringify(data));
}

/* ── ROLE HELPERS ── */
function esRevisora() {
  const s = getSession();
  return s && (s.username === 'brenda' || s.username === 'karen.reyna');
}
function puedeVerTodas() {
  const s = getSession();
  if (!s) return false;
  return esRevisora() || ['admin','manager','coordinadora'].includes(s.rol);
}

/* ── STATUS CONFIG ── */
const REV_STATUS_MAP = {
  'Nueva':                  { badge:'badge-gold',   cls:'status-nueva',        icon:'🆕' },
  'En revisión':            { badge:'badge-info',   cls:'status-en-revision',  icon:'🔍' },
  'Con observaciones':      { badge:'badge-warn',   cls:'status-observaciones',icon:'📝' },
  'Modificaciones enviadas':{ badge:'badge-purple', cls:'status-modificaciones',icon:'📨' },
  'Aprobada':               { badge:'badge-green',  cls:'status-aprobada',     icon:'✅' },
  'Lista para subir':       { badge:'badge-navy',   cls:'status-subir',        icon:'⬆️' },
  'Completada':             { badge:'badge-green',  cls:'status-completada',   icon:'🏁' },
};
function revStatusBadge(s) {
  const cfg = REV_STATUS_MAP[s] || { badge:'badge-gray', icon:'•' };
  return `<span class="badge ${cfg.badge}">${cfg.icon} ${s}</span>`;
}
function revStatusCls(s) {
  return REV_STATUS_MAP[s]?.cls || '';
}

/* ── MAIN RENDER ── */
function renderRevisiones() {
  const session = getSession();
  if (!session) return;

  const isRevisora  = esRevisora();
  const canSeeAll   = puedeVerTodas();
  const allRevs     = getRevisiones();

  // Populate trainer filter
  const ft = document.getElementById('rev-filter-trainer');
  if (ft && ft.options.length <= 1) {
    const names = [...new Set(allRevs.map(r=>r.solicitanteNombre))].filter(Boolean);
    ft.innerHTML = '<option value="">Todos los trainers</option>' +
      names.map(n=>`<option>${n}</option>`).join('');
  }

  // Page title & subtitle
  if (isRevisora) {
    document.getElementById('rev-page-title').textContent = 'Panel de Revisión DI';
    document.getElementById('rev-page-sub').textContent   = `Como revisora de diseño instruccional, aquí están todas las peticiones del equipo.`;
    document.getElementById('rev-kpi-bar').classList.remove('hidden');
    document.getElementById('rev-kpi-bar').style.display = '';
    document.getElementById('rev-filtros-wrap').classList.remove('hidden');
    document.getElementById('rev-filtros-wrap').style.display = '';
    document.getElementById('rev-header-actions').innerHTML =
      `<button class="filter-btn gold-btn" onclick="openNuevaRevisionModal()">+ Nueva petición</button>`;
  } else if (canSeeAll) {
    document.getElementById('rev-page-title').textContent = 'Revisiones DI — Vista general';
    document.getElementById('rev-page-sub').textContent   = 'Vista de lectura de todas las peticiones del equipo.';
    document.getElementById('rev-kpi-bar').classList.remove('hidden');
    document.getElementById('rev-kpi-bar').style.display = '';
    document.getElementById('rev-filtros-wrap').classList.remove('hidden');
    document.getElementById('rev-filtros-wrap').style.display = '';
    document.getElementById('rev-header-actions').innerHTML = '';
  } else {
    document.getElementById('rev-page-title').textContent = 'Mis Peticiones de Revisión DI';
    document.getElementById('rev-page-sub').textContent   = 'Registra y da seguimiento a tus peticiones de revisión de diseño instruccional.';
    document.getElementById('rev-kpi-bar').classList.add('hidden');
    document.getElementById('rev-filtros-wrap').classList.add('hidden');
    document.getElementById('rev-header-actions').innerHTML =
      `<button class="filter-btn gold-btn" onclick="openNuevaRevisionModal()">+ Nueva petición</button>`;
  }

  // Filter
  const search   = document.getElementById('rev-search')?.value.toLowerCase() || '';
  const fEstatus = document.getElementById('rev-filter-estatus')?.value || '';
  const fTrainer = document.getElementById('rev-filter-trainer')?.value || '';
  const fPrio    = document.getElementById('rev-filter-prioridad')?.value || '';

  let revs = canSeeAll
    ? allRevs
    : allRevs.filter(r => r.solicitanteUsername === session.username);

  revs = revs.filter(r => {
    if (search   && !r.titulo.toLowerCase().includes(search) && !r.solicitanteNombre.toLowerCase().includes(search)) return false;
    if (fEstatus && r.estatus !== fEstatus) return false;
    if (fTrainer && r.solicitanteNombre !== fTrainer) return false;
    if (fPrio    && r.prioridad !== fPrio) return false;
    return true;
  });

  // Update KPIs
  const ks = { nuevas:0, enrev:0, obs:0, mod:0, apro:0, comp:0 };
  allRevs.forEach(r => {
    if (r.estatus === 'Nueva')                   ks.nuevas++;
    if (r.estatus === 'En revisión')             ks.enrev++;
    if (r.estatus === 'Con observaciones')       ks.obs++;
    if (r.estatus === 'Modificaciones enviadas') ks.mod++;
    if (r.estatus === 'Aprobada' || r.estatus === 'Lista para subir') ks.apro++;
    if (r.estatus === 'Completada')              ks.comp++;
  });
  ['nuevas','enrev','obs','mod','apro','comp'].forEach(k => {
    const el = document.getElementById('rkpi-'+k);
    if (el) el.textContent = ks[k];
  });

  // Render main content
  const main = document.getElementById('rev-main-content');
  if (!main) return;

  if (!revs.length) {
    main.innerHTML = `<div class="empty-state" style="padding:60px 24px">
      <div class="empty-state-icon">${canSeeAll ? '🔍' : '📋'}</div>
      <div class="empty-state-text">
        ${canSeeAll
          ? 'Sin peticiones de revisión registradas aún.'
          : 'Aún no has registrado ninguna petición de revisión.<br><br><button class="filter-btn gold-btn" onclick="openNuevaRevisionModal()">+ Crear mi primera petición</button>'}
      </div>
    </div>`;
    return;
  }

  if (isRevisora) {
    // REVISORA VIEW — tabla ejecutiva + acciones
    main.innerHTML = `
      <div class="card">
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr>
              <th>Petición</th><th>Trainer</th><th>Tipo</th>
              <th>Prioridad</th><th>Fecha</th><th>Estatus</th><th>Material</th><th>Acciones</th>
            </tr></thead>
            <tbody>${revs.map(r => revRowRevisora(r)).join('')}</tbody>
          </table>
        </div>
      </div>`;
  } else if (canSeeAll) {
    // MANAGER/ADMIN view — read only table
    main.innerHTML = `
      <div class="card">
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr>
              <th>Petición</th><th>Trainer</th><th>Tipo</th>
              <th>Prioridad</th><th>Fecha</th><th>Revisora</th><th>Estatus</th>
            </tr></thead>
            <tbody>${revs.map(r => `
              <tr>
                <td><div class="td-main">${r.titulo}</div><div class="td-soft">${r.area||'—'}</div></td>
                <td class="td-soft">${r.solicitanteNombre}</td>
                <td><span class="badge badge-navy" style="font-size:10px">${r.tipoMaterial||'—'}</span></td>
                <td>${priorityBadge(r.prioridad)}</td>
                <td class="td-mono">${r.fechaSolicitud}</td>
                <td class="td-soft">${r.revisora||'Sin asignar'}</td>
                <td>${revStatusBadge(r.estatus)}</td>
              </tr>`).join('')}
            </tbody>
          </table>
        </div>
      </div>`;
  } else {
    // TRAINER VIEW — cards de sus propias peticiones
    const banner = `
      <div class="rev-trainer-banner">
        <div class="rev-trainer-banner-text">
          <strong>Tus peticiones de revisión DI</strong>
          Registra tus materiales para que Brenda o Karen Reyna los revisen. Puedes actualizar tu avance y agregar links en cualquier momento.
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;flex-shrink:0">
          <div style="text-align:center;background:rgba(255,255,255,0.08);border-radius:var(--radius-sm);padding:10px 16px">
            <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--gold-light)">${revs.length}</div>
            <div style="font-size:10px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:1px">Total</div>
          </div>
          <div style="text-align:center;background:rgba(255,255,255,0.08);border-radius:var(--radius-sm);padding:10px 16px">
            <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:#fca5a5">${revs.filter(r=>r.estatus==='Con observaciones').length}</div>
            <div style="font-size:10px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:1px">Con obs.</div>
          </div>
          <div style="text-align:center;background:rgba(255,255,255,0.08);border-radius:var(--radius-sm);padding:10px 16px">
            <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:#86efac">${revs.filter(r=>r.estatus==='Aprobada'||r.estatus==='Completada').length}</div>
            <div style="font-size:10px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:1px">Aprobadas</div>
          </div>
        </div>
      </div>`;

    const cards = `<div class="solicitud-grid">${revs.map(r => revCardTrainer(r, session)).join('')}</div>`;
    main.innerHTML = banner + cards;
  }
}

/* ── ROW: REVISORA ── */
function revRowRevisora(r) {
  const linkHtml = r.linkMaterial
    ? `<a href="${r.linkMaterial}" target="_blank" class="rev-link-pill">↗ Ver material</a>`
    : '<span style="color:var(--text-soft);font-size:11px">Sin link</span>';

  const acciones = [];
  if (r.estatus === 'Nueva') {
    acciones.push(`<button class="rev-btn-take" onclick="revTomarRevision('${r.id}')">Tomar revisión</button>`);
  }
  if (r.estatus === 'En revisión' || r.estatus === 'Modificaciones enviadas') {
    acciones.push(`<button class="rev-btn-obs" onclick="revDarObservaciones('${r.id}')">Con observaciones</button>`);
    acciones.push(`<button class="rev-btn-approve" onclick="revAprobar('${r.id}')">✅ Aprobar</button>`);
  }
  if (r.estatus === 'Aprobada') {
    acciones.push(`<button class="rev-btn-upload" onclick="revMarcarSubir('${r.id}')">⬆️ Lista para subir</button>`);
  }
  if (r.estatus === 'Lista para subir') {
    acciones.push(`<button class="rev-btn-approve" onclick="revCompletar('${r.id}')">🏁 Completar</button>`);
  }
  acciones.push(`<button class="btn-detail" onclick="revVerDetalle('${r.id}')">→</button>`);

  return `<tr>
    <td>
      <div class="td-main">${r.titulo}</div>
      <div class="td-soft">${r.area||'—'} · ${r.tipoMaterial||'—'}</div>
    </td>
    <td>
      <div style="display:flex;align-items:center;gap:7px">
        <div style="width:8px;height:8px;border-radius:50%;background:${calTrainerColor(r.trainerCal)||'#6b7280'};flex-shrink:0"></div>
        <span class="td-soft">${r.solicitanteNombre}</span>
      </div>
    </td>
    <td><span class="badge badge-navy" style="font-size:10px">${r.tipoMaterial||'—'}</span></td>
    <td>${priorityBadge(r.prioridad)}</td>
    <td class="td-mono">${r.fechaSolicitud}</td>
    <td>${revStatusBadge(r.estatus)}</td>
    <td>${linkHtml}</td>
    <td><div style="display:flex;gap:5px;flex-wrap:wrap">${acciones.join('')}</div></td>
  </tr>`;
}

/* ── CARD: TRAINER ── */
function revCardTrainer(r, session) {
  const cls = revStatusCls(r.estatus);
  const needsAction = r.estatus === 'Con observaciones';
  const linkMat = r.linkMaterial
    ? `<a href="${r.linkMaterial}" target="_blank" class="rev-link-pill">↗ Material</a>` : '';
  const linkInst = r.linkInstrumento
    ? `<a href="${r.linkInstrumento}" target="_blank" class="rev-link-pill" style="background:#e6f4ea;color:var(--success);border-color:#86efac">↗ Instrumento</a>` : '';

  return `<div class="rev-card ${cls}">
    <div class="rev-card-header">
      <div class="rev-card-title">${r.titulo}</div>
      ${revStatusBadge(r.estatus)}
    </div>
    <div class="rev-card-body">
      <div class="rev-card-row"><span class="rev-card-label">Área</span><span class="rev-card-val">${r.area||'—'}</span></div>
      <div class="rev-card-row"><span class="rev-card-label">Tipo</span><span class="rev-card-val">${r.tipoMaterial||'—'}</span></div>
      <div class="rev-card-row"><span class="rev-card-label">Prioridad</span>${priorityBadge(r.prioridad)}</div>
      <div class="rev-card-row"><span class="rev-card-label">Revisora</span><span class="rev-card-val">${r.revisora||'Pendiente de asignación'}</span></div>
      <div class="rev-card-row"><span class="rev-card-label">Solicitado</span><span class="rev-card-val text-mono">${r.fechaSolicitud}</span></div>
      ${linkMat || linkInst ? `<div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:4px">${linkMat}${linkInst}</div>` : ''}
      ${needsAction ? `
        <div style="background:var(--warn-bg);border:1px solid #fcd34d;border-radius:var(--radius-sm);padding:10px 12px;margin-top:6px">
          <div style="font-size:11px;font-weight:700;color:var(--warn);margin-bottom:4px">📝 Observaciones de la revisora:</div>
          <div style="font-size:12px;color:var(--text-dark)">${r.comentariosRevisora||'—'}</div>
        </div>` : ''}
      ${r.estatus === 'Aprobada' || r.estatus === 'Lista para subir' || r.estatus === 'Completada' ? `
        <div style="background:var(--success-bg);border:1px solid #86efac;border-radius:var(--radius-sm);padding:8px 12px;margin-top:4px;font-size:12px;color:var(--success)">
          ✅ ${r.estatus === 'Completada' ? 'Material subido al instrumento correctamente.' : 'Material aprobado por la revisora.'}
        </div>` : ''}
    </div>
    <div class="rev-card-footer">
      <button class="btn-detail" onclick="revVerDetalle('${r.id}')">Ver detalle</button>
      ${['Nueva','Con observaciones','Modificaciones enviadas'].includes(r.estatus)
        ? `<button class="rev-btn-update" onclick="revActualizarTrainer('${r.id}')">📨 Actualizar avance</button>` : ''}
      ${r.estatus === 'Con observaciones'
        ? `<button class="rev-btn-update" onclick="revEnviarModificaciones('${r.id}')">✔ Modificaciones listas</button>` : ''}
    </div>
  </div>`;
}

