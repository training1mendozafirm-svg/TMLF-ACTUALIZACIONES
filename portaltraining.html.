#cal-v49 .di-badge.tipo-revision { background: #fef3c7; color: #92400e; }
#cal-v49 .di-badge.tipo-actualizacion { background: #dbeafe; color: #1e40af; }
#cal-v49 .di-badge.prio-alta { background: #fee2e2; color: #991b1b; }
#cal-v49 .di-badge.prio-media { background: #fef3c7; color: #92400e; }
#cal-v49 .di-badge.prio-baja { background: #d1fae5; color: #065f46; }
#cal-v49 .di-deadline { font-size: 10.5px; color: var(--text-3); }
