// ── CRUD E-Learning ───────────────────────────────────────
async function cargarElSesiones() {
  if (!CAL49_WEB_APP_URL) { renderElTable(); updateElKpis(); return; }
  const url = CAL49_WEB_APP_URL + '?action=getAll&sheet=' + EL_SHEET + '&t=' + Date.now();

  const fetchData = () => new Promise((resolve, reject) => {
    // Intentar fetch cors primero
    fetch(url, { method:'GET', redirect:'follow', mode:'cors', cache:'no-cache' })
      .then(r => r.text()).then(resolve).catch(() => {
        // Fallback JSONP
        const cb = '_elcb' + Date.now();
        const s  = document.createElement('script');
        const t  = setTimeout(() => {
          delete window[cb];
          if (document.body.contains(s)) document.body.removeChild(s);
          reject(new Error('Timeout'));
        }, 10000);
        window[cb] = d => {
          clearTimeout(t);
          delete window[cb];
          if (document.body.contains(s)) document.body.removeChild(s);
          resolve(JSON.stringify(d));
        };
        s.src = url + '&callback=' + cb;
        s.onerror = () => { clearTimeout(t); reject(new Error('Script error')); };
        document.body.appendChild(s);
      });
  });

  try {
    const text = await fetchData();
    let data;
    try { data = JSON.parse(text); }
    catch(e) { const m = text.match(/\{[\s\S]*\}/); if (m) data = JSON.parse(m[0]); else throw e; }
    if (data?.ok) {
      elSesiones = data.elSesiones || data.cal49Eventos || [];
    } else {
      elSesiones = [];
    }
  } catch(err) {
    elSesiones = [];
  }
  renderElTable();
  renderElCalendar();
  updateElKpis();
  setTimeout(() => { try { if(elCalendar) elCalendar.updateSize(); } catch(e){} }, 150);
}

async function apiPostEl(body) {
  if (!CAL49_WEB_APP_URL) return;
  body.sheet = EL_SHEET;
  const url = CAL49_WEB_APP_URL + '?data=' + encodeURIComponent(JSON.stringify(body)) + '&t=' + Date.now();
  try {
    await fetch(url, { method:'GET', mode:'no-cors', redirect:'follow', cache:'no-cache' });
    setTimeout(() => cargarElSesiones(), 2500);
  } catch(err) {
    console.error('apiPostEl error:', err);
  }
}

