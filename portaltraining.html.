function renderPanelManager() {
  const users   = (typeof getUsers === 'function' ? getUsers() : null) || [];
  const trainers = users.filter(u => u.activo && u.trainer);
  const now = new Date(); now.setHours(0,0,0,0);
  const en14 = new Date(now.getTime() + 14*86400000);
  const realEvents = calEventos.filter(e => !['Vacaciones','Cumpleaños','Día OFF'].includes(e.tipoActividad));
  const maxCnt = Math.max(1, ...trainers.map(u => realEvents.filter(e=>e.trainer===u.trainer).length));

  // Carga por trainer
  const cargaEl = document.getElementById('mgr-carga-trainers');
  if (cargaEl) {
    if (!trainers.length) {
      cargaEl.innerHTML = `<div class="empty-state" style="padding:24px 0"><div class="empty-state-icon">👥</div><div>Sin trainers registrados</div></div>`;
    } else {
      cargaEl.innerHTML = trainers.map(u => {
        const count = realEvents.filter(e=>e.trainer===u.trainer).length;
        const pct   = Math.round((count/maxCnt)*100);
        const cls   = pct>=80?'crit':pct>=60?'high':pct>=30?'mid':'low';
        const color = calTrainerColor(u.trainer) || u.color;
        return `<div style="margin-bottom:18px">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:28px;height:28px;border-radius:50%;background:${color};display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:10px;font-weight:700;color:white">${u.iniciales}</div>
              <div>
                <div style="font-size:13px;font-weight:600;color:var(--navy)">${u.nombre}</div>
                <div style="font-size:11px;color:var(--text-soft)">Trainer</div>
              </div>
            </div>
            <div style="text-align:right">
              <div style="font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--navy)">${count}</div>
              <div style="font-size:10px;color:var(--text-soft)">actividades</div>
            </div>
          </div>
          <div class="workload-bar" style="height:10px"><div class="workload-fill ${cls}" style="width:${pct}%"></div></div>
        </div>`;
      }).join('');
    }
  }

  // Pendientes críticos
  const criticos = SOLICITUDES.filter(s => (s.prioridad==='Crítica'||s.prioridad==='Alta') && s.estatus!=='Completada');
  const crEl = document.getElementById('mgr-pendientes-criticos');
  if (crEl) {
    crEl.innerHTML = criticos.length
      ? criticos.map(s => `
        <div class="agenda-item">
          <div class="agenda-content">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
              <div class="agenda-title">${s.titulo||s.title||'—'}</div>
              ${statusBadge(s.estatus)}
            </div>
            <div class="agenda-meta">${priorityBadge(s.prioridad)} <span>${s.asignada||''}</span></div>
          </div>
        </div>`).join('')
      : `<div class="empty-state" style="padding:20px 0"><div class="empty-state-icon">✅</div><div>Sin pendientes críticos</div></div>`;
  }

  // Timeline de entregas (del calendario real)
  const upcoming = realEvents
    .filter(e => ['Entregable','Planeación'].includes(e.tipoActividad) || (e.start && calParseLocal(e.start) >= now))
    .sort((a,b)=>calParseLocal(a.start)-calParseLocal(b.start))
    .slice(0,6);
  const tlEl = document.getElementById('mgr-timeline');
  if (tlEl) {
    tlEl.innerHTML = upcoming.length
      ? upcoming.map(e => {
          const d = calParseLocal(e.start);
          const isLate = d < now;
          const icon = CAL_TIPOS_ICON[e.tipoActividad]||'📌';
          return `<div class="timeline-item ${isLate?'late':''}">
            <div class="timeline-date">${d.toLocaleDateString('es-MX',{day:'numeric',month:'long'})}</div>
            <div class="timeline-title">${icon} ${e.title}</div>
            <div class="timeline-meta">${e.trainer||'—'} · ${e.tipoActividad}</div>
          </div>`;
        }).join('')
      : `<div class="empty-state" style="padding:20px 0"><div>Sin actividades próximas en el calendario</div></div>`;
  }

  // Trainings programados
  const trainings = realEvents
    .filter(e => ['Training teórico','Training práctico','Habilitación'].includes(e.tipoActividad) && calParseLocal(e.start)>=now)
    .sort((a,b)=>calParseLocal(a.start)-calParseLocal(b.start))
    .slice(0,5);
  const tEl = document.getElementById('mgr-trainings-list');
  if (tEl) {
    tEl.innerHTML = trainings.length
      ? trainings.map(e => {
          const d = calParseLocal(e.start);
          const color = calTrainerColor(e.trainer);
          const timeStr = e.start.includes('T') ? d.toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'}) : 'Todo el día';
          return `<div class="agenda-item">
            <div class="agenda-date-box">
              <div class="agenda-date-day">${d.getDate()}</div>
              <div class="agenda-date-month">${d.toLocaleDateString('es-MX',{month:'short'}).toUpperCase()}</div>
            </div>
            <div class="agenda-content">
              <div class="agenda-title">${e.title}</div>
              <div class="agenda-meta">
                <span style="color:${color};font-weight:600">${e.trainer||'—'}</span>
                <span>🕐 ${timeStr}</span>
                <span>${e.sala||''}</span>
              </div>
            </div>
          </div>`;
        }).join('')
      : `<div class="empty-state" style="padding:20px 0"><div class="empty-state-icon">🎓</div><div>Sin trainings próximos</div></div>`;
  }

  // Resumen ejecutivo dinámico
  const mesEvs = realEvents.filter(e => {
    const d = calParseLocal(e.start);
    return d.getMonth()===now.getMonth() && d.getFullYear()===now.getFullYear();
  });
  const trainingsMes = mesEvs.filter(e=>['Training teórico','Training práctico','Habilitación'].includes(e.tipoActividad));
  const resumen = [
    { icon:'📊', titulo:'Actividades este mes', val: mesEvs.length||'0',           sub:'Total en el calendario', color:'var(--gold)' },
    { icon:'🎓', titulo:'Trainings este mes',    val: trainingsMes.length||'0',     sub:'Teórico, práctico, habilitación', color:'var(--success)' },
    { icon:'👥', titulo:'Trainers activos',       val: trainers.length||'0',         sub:'Con acceso al portal', color:'var(--navy)' },
    { icon:'📋', titulo:'Solicitudes abiertas',   val: SOLICITUDES.filter(s=>s.estatus!=='Completada').length||'0', sub:'Sin completar', color:'var(--warn)' },
    { icon:'📁', titulo:'Materiales registrados', val: MATERIALES.length||'0',       sub:'En el repositorio', color:'var(--info)' },
    { icon:'🔍', titulo:'Revisiones DI',           val: REVISIONES.length||'0',       sub:'Total registradas', color:'var(--purple)' },
  ];
  const resEl = document.getElementById('mgr-resumen-ejecutivo');
  if (resEl) {
    resEl.innerHTML = resumen.map(r => `
      <div style="padding:16px;background:var(--beige);border-radius:var(--radius-sm);border-left:3px solid ${r.color}">
        <div style="font-size:20px;margin-bottom:8px">${r.icon}</div>
        <div style="font-family:var(--font-mono);font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:var(--text-soft);margin-bottom:4px">${r.titulo}</div>
        <div style="font-family:var(--font-display);font-size:26px;font-weight:700;color:var(--navy);margin-bottom:3px">${r.val}</div>
        <div style="font-size:11px;color:var(--text-soft)">${r.sub}</div>
      </div>`).join('');
  }

  // Manager KPI cards
  const mgrCards = [
    { sel:'.mgr-card:nth-child(1) .mgr-card-val', val: mesEvs.length || '0' },
    { sel:'.mgr-card:nth-child(2) .mgr-card-val', val: SOLICITUDES.filter(s=>s.estatus!=='Completada').length || '0' },
    { sel:'.mgr-card:nth-child(3) .mgr-card-val', val: MATERIALES.length || '0' },
    { sel:'.mgr-card:nth-child(4) .mgr-card-val', val: trainingsMes.length || '0' },
  ];
  mgrCards.forEach(c => {
    const el = document.querySelector(c.sel);
    if (el) el.textContent = c.val;
  });
}

/* ============================================================
   EQUIPO RENDER — from registered users + cal data
   ============================================================ */
function renderEquipo(rolFilter) {
  const users = (typeof getUsers === 'function' ? getUsers() : null) || [];
  const realEvents = calEventos.filter(e => !['Vacaciones','Cumpleaños','Día OFF'].includes(e.tipoActividad));
  const now = new Date(); now.setHours(0,0,0,0);
  const en14 = new Date(now.getTime() + 14*86400000);

  let data = users.filter(u => u.activo);
  if (rolFilter) data = data.filter(u => u.rol === rolFilter);

  const gridEl = document.getElementById('equipo-grid');
  if (!gridEl) return;

  if (!data.length) {
    gridEl.innerHTML = `<div class="empty-state" style="grid-column:1/-1;padding:48px">
      <div class="empty-state-icon">👥</div>
      <div>Sin usuarios registrados con este filtro</div>
    </div>`;
    return;
  }

  gridEl.innerHTML = data.map(u => {
    const color   = calTrainerColor(u.trainer) || u.color || '#6b7280';
    const evTotal = u.trainer ? realEvents.filter(e=>e.trainer===u.trainer).length : 0;
    const evProx  = u.trainer ? realEvents.filter(e=>{
      const d=calParseLocal(e.start);d.setHours(0,0,0,0);
      return e.trainer===u.trainer && d>=now && d<=en14;
    }).length : 0;
    const rolLabel = ROL_LABEL[u.rol] || u.rol;
    const rolBadge = ROL_BADGE[u.rol] || 'badge-gray';
    const maxEvs   = Math.max(1,...data.filter(x=>x.trainer).map(x=>realEvents.filter(e=>e.trainer===x.trainer).length));
    const pct      = u.trainer ? Math.round((evTotal/maxEvs)*100) : 0;
    const cls      = pct>=80?'high':pct>=50?'mid':'low';

    return `<div class="trainer-card">
      <div class="trainer-card-top" style="background:linear-gradient(135deg,${color}ee,${color}99)">
        <div class="trainer-avatar" style="background:rgba(255,255,255,0.25);border-color:rgba(255,255,255,0.3)">${u.iniciales}</div>
        <div class="trainer-name">${u.nombre}</div>
        <div class="trainer-role">${rolLabel}</div>
        <div style="margin-top:8px"><span class="badge ${rolBadge}">${rolLabel}</span></div>
      </div>
      <div class="trainer-card-body">
        <div class="trainer-stat-row">
          <div class="trainer-stat"><div class="trainer-stat-val">${evTotal}</div><div class="trainer-stat-lbl">Total act.</div></div>
          <div class="trainer-stat"><div class="trainer-stat-val">${evProx}</div><div class="trainer-stat-lbl">Próx. 14d</div></div>
          <div class="trainer-stat"><div class="trainer-stat-val">${SOLICITUDES.filter(s=>s.asignada===u.nombre).length||0}</div><div class="trainer-stat-lbl">Solicitudes</div></div>
        </div>
        ${u.trainer ? `
          <div class="trainer-tags" style="margin-bottom:10px">
            <span class="trainer-tag">🎓 ${u.trainer}</span>
          </div>
          <div class="trainer-load">
            <div class="trainer-load-label">
              <span>Actividad relativa</span>
              <span style="font-weight:600;color:${pct>=80?'var(--danger)':pct>=50?'var(--warn)':'var(--success)'}">${pct}%</span>
            </div>
            <div class="workload-bar"><div class="workload-fill ${cls}" style="width:${pct}%"></div></div>
          </div>` : `<div style="font-size:12px;color:var(--text-soft);padding:8px 0">${rolLabel} — sin trainer vinculado</div>`}
        <div style="margin-top:12px;font-size:11px;color:var(--text-soft)">
          👤 <span style="font-family:var(--font-mono)">${u.username}</span>
          <span style="margin-left:10px;color:${u.activo?'var(--success)':'var(--danger)'}">● ${u.activo?'Activo':'Inactivo'}</span>
        </div>
      </div>
    </div>`;
  }).join('');
}

