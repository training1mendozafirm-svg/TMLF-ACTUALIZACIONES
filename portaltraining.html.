<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TMLF Training Center — Portal Operativo</title>
<!-- FullCalendar v6 (para el calendario de trainers) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ============================================================
   CSS VARIABLES & RESET
   ============================================================ */
:root {
  --navy:        #0d1b2a;
  --navy-mid:    #1a2e45;
  --navy-light:  #243b55;
  --gold:        #c9a84c;
  --gold-light:  #e8c86a;
  --gold-pale:   #f5e8c0;
  --beige:       #f8f3ea;
  --beige-mid:   #ede4d3;
  --beige-dark:  #ddd0bb;
  --cream:       #fdfaf5;
  --white:       #ffffff;
  --text-dark:   #1a1a2e;
  --text-mid:    #3a3a5c;
  --text-soft:   #6b6b8a;
  --success:     #2e7d5e;
  --success-bg:  #d4eddf;
  --danger:      #c62828;
  --danger-bg:   #fdecea;
  --warn:        #b45309;
  --warn-bg:     #fef3c7;
  --info:        #1d4ed8;
  --info-bg:     #dbeafe;
  --purple:      #6b21a8;
  --purple-bg:   #f3e8ff;
  --locked:      #9e9e9e;
  --locked-bg:   #f0f0f0;
  --font-display:'Playfair Display', serif;
  --font-body:   'DM Sans', sans-serif;
  --font-mono:   'DM Mono', monospace;
  --shadow-sm:   0 2px 8px rgba(13,27,42,0.08);
  --shadow-md:   0 8px 32px rgba(13,27,42,0.12);
  --shadow-lg:   0 20px 60px rgba(13,27,42,0.18);
  --shadow-gold: 0 4px 20px rgba(201,168,76,0.3);
  --radius-sm:   8px;
  --radius-md:   14px;
  --radius-lg:   20px;
  --radius-xl:   32px;
  --sidebar-w:   240px;
  --header-h:    64px;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { font-family:var(--font-body); background:var(--beige); color:var(--text-dark); min-height:100vh; overflow-x:hidden; }
input,select,textarea,button { font-family:var(--font-body); }
button { cursor:pointer; }
.hidden { display:none !important; }
a { text-decoration:none; color:inherit; }

/* ============================================================
   BADGES
   ============================================================ */
.badge {
  display:inline-flex; align-items:center; gap:4px;
  padding:3px 10px; border-radius:20px;
  font-size:11px; font-weight:600; letter-spacing:0.4px;
  font-family:var(--font-mono); white-space:nowrap;
}
.badge-gold    { background:var(--gold-pale);    color:#8b6914; }
.badge-navy    { background:var(--navy);          color:var(--gold-light); }
.badge-green   { background:var(--success-bg);    color:var(--success); }
.badge-gray    { background:var(--locked-bg);     color:var(--locked); }
.badge-red     { background:var(--danger-bg);     color:var(--danger); }
.badge-warn    { background:var(--warn-bg);       color:var(--warn); }
.badge-info    { background:var(--info-bg);       color:var(--info); }
.badge-purple  { background:var(--purple-bg);     color:var(--purple); }

/* ============================================================
   LOADER
   ============================================================ */
#loader {
  position:fixed; inset:0; z-index:9999;
  background:var(--navy);
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:18px;
  transition:opacity 0.7s ease, visibility 0.7s ease;
}
#loader.fade-out { opacity:0; visibility:hidden; }
.loader-logo   { font-family:var(--font-display); font-size:48px; font-weight:900; color:var(--gold-light); letter-spacing:-1px; }
.loader-sub    { font-family:var(--font-mono); font-size:10px; color:rgba(255,255,255,0.35); letter-spacing:4px; text-transform:uppercase; }
.loader-bar    { width:200px; height:2px; background:rgba(255,255,255,0.1); border-radius:2px; overflow:hidden; }
.loader-fill   { height:100%; background:var(--gold); border-radius:2px; animation:loadFill 1.8s ease forwards; }
@keyframes loadFill { from{width:0} to{width:100%} }

/* ============================================================
   TOAST
   ============================================================ */
#toast-container { position:fixed; bottom:24px; right:24px; z-index:9000; display:flex; flex-direction:column; gap:10px; }
.toast {
  background:var(--navy); color:white;
  padding:12px 18px; border-radius:var(--radius-sm);
  font-size:13px; font-weight:500;
  box-shadow:var(--shadow-md);
  border-left:3px solid var(--gold);
  animation:slideInToast 0.3s ease;
  max-width:320px;
}
.toast.success { border-left-color:var(--success); }
.toast.error   { border-left-color:var(--danger); }
@keyframes slideInToast { from{transform:translateX(120%);opacity:0} to{transform:translateX(0);opacity:1} }

/* ============================================================
   HEADER
   ============================================================ */
header {
  position:sticky; top:0; z-index:500;
  background:rgba(253,250,245,0.96);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--beige-dark);
  height:var(--header-h);
  padding:0 28px;
  display:flex; align-items:center; justify-content:space-between; gap:16px;
}
.header-brand {
  display:flex; align-items:center; gap:10px; flex-shrink:0;
}
.header-brand-logo {
  width:34px; height:34px;
  background:var(--navy);
  border-radius:var(--radius-sm);
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:14px; font-weight:900; color:var(--gold-light);
}
.header-brand-name {
  font-family:var(--font-display); font-size:18px; font-weight:700; color:var(--navy);
}
.header-brand-name span { color:var(--gold); }
.header-center { flex:1; display:flex; justify-content:center; }
.header-current-section {
  font-family:var(--font-mono); font-size:11px;
  color:var(--text-soft); letter-spacing:2px; text-transform:uppercase;
}
.header-right { display:flex; align-items:center; gap:10px; flex-shrink:0; }
.header-date {
  font-family:var(--font-mono); font-size:11px; color:var(--text-soft);
  background:var(--beige); padding:5px 12px; border-radius:20px;
  border:1px solid var(--beige-dark);
}
.header-pending-btn {
  position:relative;
  background:var(--navy); color:white;
  border:none; border-radius:var(--radius-sm);
  padding:7px 14px; font-size:12px; font-weight:600;
  display:flex; align-items:center; gap:7px;
  transition:all 0.2s;
}
.header-pending-btn:hover { background:var(--navy-light); }
.pending-bubble {
  background:var(--danger); color:white;
  width:18px; height:18px; border-radius:50%;
  font-size:10px; font-weight:700;
  display:flex; align-items:center; justify-content:center;
}
.header-quick-btn {
  background:var(--gold); color:var(--navy);
  border:none; border-radius:var(--radius-sm);
  padding:7px 16px; font-size:12px; font-weight:700;
  transition:all 0.2s;
}
.header-quick-btn:hover { background:var(--gold-light); transform:translateY(-1px); box-shadow:var(--shadow-gold); }
.header-avatar {
  width:36px; height:36px; border-radius:50%;
  background:linear-gradient(135deg, var(--gold), var(--navy));
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:13px; font-weight:700; color:white;
  border:2px solid var(--gold-pale); cursor:pointer;
  position:relative; flex-shrink:0;
}
.avatar-menu {
  position:absolute; top:calc(100% + 8px); right:0;
  background:white; border:1px solid var(--beige-dark);
  border-radius:var(--radius-md); box-shadow:var(--shadow-md);
  min-width:180px; overflow:hidden; z-index:600;
}
.avatar-menu-item {
  padding:11px 16px; font-size:13px; color:var(--text-dark);
  display:flex; align-items:center; gap:8px;
  transition:background 0.15s;
}
.avatar-menu-item:hover { background:var(--beige); }
.avatar-menu-sep { height:1px; background:var(--beige-mid); }

/* ============================================================
   LAYOUT
   ============================================================ */
.app-layout {
  display:flex;
  min-height:calc(100vh - var(--header-h));
}

/* ============================================================
   SIDEBAR
   ============================================================ */
.sidebar {
  width:var(--sidebar-w); flex-shrink:0;
  background:white;
  border-right:1px solid var(--beige-dark);
  position:sticky; top:var(--header-h);
  height:calc(100vh - var(--header-h));
  overflow-y:auto; overflow-x:hidden;
  padding:20px 0 40px;
}
.sidebar-group-title {
  font-family:var(--font-mono); font-size:9px;
  color:var(--text-soft); letter-spacing:2.5px; text-transform:uppercase;
  padding:14px 20px 5px;
}
.sidebar-item {
  display:flex; align-items:center; gap:10px;
  padding:9px 20px;
  font-size:13px; font-weight:500;
  color:var(--text-mid);
  cursor:pointer;
  transition:all 0.15s;
  border-left:3px solid transparent;
  position:relative;
}
.sidebar-item:hover { background:var(--beige); color:var(--navy); }
.sidebar-item.active {
  background:var(--gold-pale);
  color:var(--navy);
  border-left-color:var(--gold);
  font-weight:600;
}
.sidebar-item .si-icon { font-size:15px; width:20px; text-align:center; flex-shrink:0; }
.sidebar-item .si-badge {
  margin-left:auto;
  background:var(--danger); color:white;
  width:18px; height:18px; border-radius:50%;
  font-size:10px; font-weight:700;
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-mono);
}
.sidebar-item .si-badge.si-badge-warn { background:var(--warn); }
.sidebar-divider { height:1px; background:var(--beige-mid); margin:12px 0; }

/* ============================================================
   MAIN CONTENT & SECTIONS
   ============================================================ */
.main-content { flex:1; overflow:hidden; min-width:0; }
.section { display:none; animation:fadeUp 0.3s ease; }
.section.active { display:block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
.page-container { max-width:1280px; margin:0 auto; padding:36px 32px 60px; }
.page-header { margin-bottom:28px; }
.page-title { font-family:var(--font-display); font-size:28px; font-weight:700; color:var(--navy); margin-bottom:4px; }
.page-subtitle { font-size:14px; color:var(--text-soft); }

/* ============================================================
   DASHBOARD HERO BANNER
   ============================================================ */
.dash-hero {
  background:linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 55%, #1e3a5f 100%);
  padding:40px 36px;
  position:relative; overflow:hidden;
}
.dash-hero::before {
  content:''; position:absolute; inset:0;
  background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23c9a84c' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.dash-hero-inner { max-width:1280px; margin:0 auto; position:relative; z-index:1; display:flex; align-items:flex-start; justify-content:space-between; gap:32px; flex-wrap:wrap; }
.dash-hero-left { flex:1; min-width:260px; }
.dash-hero-tag { font-family:var(--font-mono); font-size:10px; color:var(--gold); letter-spacing:3px; text-transform:uppercase; margin-bottom:10px; }
.dash-hero-title { font-family:var(--font-display); font-size:clamp(24px,3vw,38px); font-weight:900; color:white; line-height:1.15; margin-bottom:10px; }
.dash-hero-title span { color:var(--gold-light); }
.dash-hero-sub { font-size:14px; color:rgba(255,255,255,0.55); line-height:1.6; max-width:460px; }
.dash-hero-stats { display:flex; gap:32px; flex-wrap:wrap; margin-top:24px; }
.dash-hero-stat-val { font-family:var(--font-display); font-size:30px; font-weight:700; color:var(--gold-light); line-height:1; }
.dash-hero-stat-lbl { font-size:10px; color:rgba(255,255,255,0.4); letter-spacing:1px; text-transform:uppercase; margin-top:3px; }
.dash-hero-right { display:flex; gap:16px; flex-wrap:wrap; align-items:flex-start; }
.dash-hero-box {
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(201,168,76,0.2);
  border-radius:var(--radius-lg);
  padding:18px 22px; min-width:130px;
  text-align:center;
}
.dash-hero-box-val { font-family:var(--font-display); font-size:38px; font-weight:900; color:var(--gold-light); line-height:1; }
.dash-hero-box-val.warn { color:#fca5a5; }
.dash-hero-box-lbl { font-family:var(--font-mono); font-size:9px; color:rgba(255,255,255,0.35); letter-spacing:2px; text-transform:uppercase; margin-top:5px; }

/* ============================================================
   KPI CARDS
   ============================================================ */
.kpi-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:16px; margin-bottom:28px; }
.kpi-card {
  background:white; border-radius:var(--radius-md);
  border:1px solid var(--beige-dark);
  padding:20px 22px;
  box-shadow:var(--shadow-sm);
  transition:box-shadow 0.2s, transform 0.2s;
}
.kpi-card:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
.kpi-card-label { font-family:var(--font-mono); font-size:10px; color:var(--text-soft); letter-spacing:1.5px; text-transform:uppercase; margin-bottom:8px; }
.kpi-card-value { font-family:var(--font-display); font-size:34px; font-weight:700; color:var(--navy); line-height:1; }
.kpi-card-sub { font-size:12px; color:var(--text-soft); margin-top:6px; }
.kpi-card-trend { display:flex; align-items:center; gap:4px; margin-top:10px; font-size:12px; font-weight:500; }
.trend-up   { color:var(--success); }
.trend-down { color:var(--danger); }
.kpi-card.accent-gold  { border-left:3px solid var(--gold); }
.kpi-card.accent-green { border-left:3px solid var(--success); }
.kpi-card.accent-warn  { border-left:3px solid var(--warn); }
.kpi-card.accent-red   { border-left:3px solid var(--danger); }
.kpi-card.accent-navy  { border-left:3px solid var(--navy); }

/* ============================================================
   CONTENT CARDS
   ============================================================ */
.card {
  background:white; border-radius:var(--radius-md);
  border:1px solid var(--beige-dark);
  box-shadow:var(--shadow-sm);
  overflow:hidden;
}
.card-header {
  padding:18px 22px 14px;
  border-bottom:1px solid var(--beige-mid);
  display:flex; align-items:center; justify-content:space-between; gap:12px;
}
.card-title { font-family:var(--font-display); font-size:16px; font-weight:700; color:var(--navy); }
.card-subtitle { font-size:12px; color:var(--text-soft); margin-top:2px; }
.card-body { padding:18px 22px; }
.card-footer { padding:14px 22px; border-top:1px solid var(--beige-mid); background:var(--beige); }

/* ============================================================
   TWO-COLUMN GRID
   ============================================================ */
.grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
.grid-auto { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:20px; }
@media(max-width:900px) { .grid-2,.grid-3 { grid-template-columns:1fr; } }

/* ============================================================
   TABLES
   ============================================================ */
.table-wrap { overflow-x:auto; }
table.data-table { width:100%; border-collapse:collapse; font-size:13px; }
table.data-table thead th {
  background:var(--navy); color:rgba(255,255,255,0.75);
  font-family:var(--font-mono); font-size:10px; letter-spacing:1.5px; text-transform:uppercase;
  padding:11px 14px; text-align:left; white-space:nowrap;
}
table.data-table thead th:first-child { border-radius:var(--radius-sm) 0 0 0; }
table.data-table thead th:last-child  { border-radius:0 var(--radius-sm) 0 0; }
table.data-table tbody tr { border-bottom:1px solid var(--beige-mid); transition:background 0.15s; }
table.data-table tbody tr:hover { background:var(--beige); }
table.data-table tbody td { padding:11px 14px; color:var(--text-dark); vertical-align:middle; }
table.data-table tbody tr:last-child { border-bottom:none; }
.td-main  { font-weight:600; color:var(--navy); }
.td-soft  { color:var(--text-soft); font-size:12px; }
.td-mono  { font-family:var(--font-mono); font-size:11px; color:var(--text-soft); }

/* ============================================================
   FILTERS ROW
   ============================================================ */
.filters-row {
  display:flex; align-items:center; gap:10px; flex-wrap:wrap;
  padding:14px 22px;
  border-bottom:1px solid var(--beige-mid);
  background:var(--cream);
}
.filter-select, .filter-input {
  padding:7px 12px; border:1px solid var(--beige-dark);
  border-radius:var(--radius-sm); font-size:12px;
  background:white; color:var(--text-dark);
  transition:border-color 0.2s;
  min-width:130px;
}
.filter-select:focus, .filter-input:focus { outline:none; border-color:var(--gold); }
.filter-input { min-width:200px; }
.filter-btn {
  padding:7px 16px; border-radius:var(--radius-sm);
  border:1px solid var(--beige-dark); background:white;
  font-size:12px; color:var(--text-mid); font-weight:500;
  transition:all 0.15s;
}
.filter-btn:hover { border-color:var(--navy); color:var(--navy); }
.filter-btn.primary-btn {
  background:var(--navy); color:var(--gold-light);
  border-color:var(--navy); font-weight:600;
}
.filter-btn.primary-btn:hover { background:var(--navy-light); }
.filter-btn.gold-btn {
  background:var(--gold); color:var(--navy);
  border-color:var(--gold); font-weight:700;
}
.filter-btn.gold-btn:hover { background:var(--gold-light); box-shadow:var(--shadow-gold); }

/* ============================================================
   PROGRESS BARS
   ============================================================ */
.progress-bar { width:100%; height:6px; background:var(--beige-mid); border-radius:3px; overflow:hidden; }
.progress-bar-fill { height:100%; background:linear-gradient(90deg, var(--gold), var(--gold-light)); border-radius:3px; transition:width 0.8s ease; }
.progress-bar-fill.green { background:linear-gradient(90deg,#2e7d5e,#4caf82); }
.progress-bar-fill.red   { background:linear-gradient(90deg,var(--danger),#ef5350); }

/* ============================================================
   ALERT BANNER
   ============================================================ */
.alert-banner {
  display:flex; align-items:flex-start; gap:12px;
  padding:14px 18px; border-radius:var(--radius-sm);
  margin-bottom:16px; font-size:13px;
}
.alert-banner.warn  { background:var(--warn-bg);    border:1px solid #fcd34d; color:var(--warn); }
.alert-banner.red   { background:var(--danger-bg);  border:1px solid #fca5a5; color:var(--danger); }
.alert-banner.green { background:var(--success-bg); border:1px solid #86efac; color:var(--success); }
.alert-banner.navy  { background:#eef2f8;            border:1px solid #bfccdc; color:var(--navy-mid); }
.alert-icon { font-size:16px; flex-shrink:0; margin-top:1px; }
.alert-body strong { font-weight:700; display:block; margin-bottom:2px; }

/* ============================================================
   MODAL
   ============================================================ */
.modal-overlay {
  position:fixed; inset:0; z-index:800;
  background:rgba(13,27,42,0.55);
  backdrop-filter:blur(4px);
  display:flex; align-items:center; justify-content:center;
  padding:24px;
  animation:fadeModal 0.2s ease;
}
@keyframes fadeModal { from{opacity:0} to{opacity:1} }
.modal-box {
  background:white; border-radius:var(--radius-lg);
  box-shadow:var(--shadow-lg);
  width:100%; max-width:580px;
  max-height:90vh; overflow-y:auto;
  animation:slideModal 0.25s ease;
}
.modal-box.modal-lg { max-width:760px; }
@keyframes slideModal { from{transform:translateY(20px);opacity:0} to{transform:translateY(0);opacity:1} }
.modal-header {
  padding:22px 26px 16px;
  border-bottom:1px solid var(--beige-mid);
  display:flex; align-items:flex-start; justify-content:space-between; gap:12px;
}
.modal-title  { font-family:var(--font-display); font-size:20px; font-weight:700; color:var(--navy); }
.modal-sub    { font-size:12px; color:var(--text-soft); margin-top:3px; }
.modal-close  { background:var(--beige); border:none; border-radius:50%; width:32px; height:32px; font-size:18px; color:var(--text-soft); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all 0.15s; }
.modal-close:hover { background:var(--beige-mid); color:var(--navy); }
.modal-body   { padding:22px 26px; }
.modal-footer { padding:16px 26px; border-top:1px solid var(--beige-mid); display:flex; align-items:center; justify-content:flex-end; gap:10px; }
.form-group  { margin-bottom:16px; }
.form-label  { display:block; font-size:11px; font-weight:600; color:var(--text-mid); letter-spacing:0.5px; text-transform:uppercase; margin-bottom:6px; }
.form-control {
  width:100%; padding:10px 14px;
  border:1px solid var(--beige-dark); border-radius:var(--radius-sm);
  font-size:14px; color:var(--text-dark);
  background:white;
  transition:border-color 0.2s;
}
.form-control:focus { outline:none; border-color:var(--gold); }
textarea.form-control { min-height:100px; resize:vertical; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }

/* ============================================================
   QUICK ACCESS CARDS
   ============================================================ */
.quick-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:14px; margin-bottom:28px; }
.quick-card {
  background:white; border:1px solid var(--beige-dark);
  border-radius:var(--radius-md); padding:18px 16px;
  display:flex; flex-direction:column; align-items:center; gap:8px;
  cursor:pointer; transition:all 0.2s;
  box-shadow:var(--shadow-sm); text-align:center;
}
.quick-card:hover { border-color:var(--gold); box-shadow:var(--shadow-gold); transform:translateY(-2px); }
.quick-icon { font-size:24px; }
.quick-label { font-size:12px; font-weight:600; color:var(--navy); }
.quick-desc  { font-size:11px; color:var(--text-soft); }

/* ============================================================
   CALENDAR
   ============================================================ */
.cal-grid {
  display:grid; grid-template-columns:repeat(7,1fr); gap:2px;
  background:var(--beige-mid); border-radius:var(--radius-sm); overflow:hidden;
}
.cal-day-header {
  background:var(--navy); padding:8px 4px;
  font-family:var(--font-mono); font-size:9px; letter-spacing:1px;
  text-transform:uppercase; color:rgba(255,255,255,0.55);
  text-align:center;
}
.cal-cell {
  background:white; min-height:92px; padding:6px;
  cursor:pointer; transition:background 0.15s; position:relative;
}
.cal-cell:hover { background:var(--beige); }
.cal-cell.other-month { background:#fafafa; opacity:0.5; }
.cal-cell.today { background:var(--gold-pale); }
.cal-cell.today .cal-date { background:var(--navy); color:white; }
.cal-date {
  font-family:var(--font-mono); font-size:11px; font-weight:600;
  color:var(--text-mid); width:22px; height:22px;
  border-radius:50%; display:flex; align-items:center; justify-content:center;
  margin-bottom:4px;
}
.cal-event {
  padding:2px 5px; border-radius:3px;
  font-size:9px; font-weight:600;
  margin-bottom:2px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;
  cursor:pointer;
}
.cal-event.type-training { background:#dbeafe; color:var(--info); }
.cal-event.type-entrega  { background:var(--warn-bg);   color:var(--warn); }
.cal-event.type-revision { background:var(--gold-pale); color:#8b6914; }
.cal-event.type-junta    { background:var(--success-bg);color:var(--success); }
.cal-event.type-deadline { background:var(--danger-bg); color:var(--danger); }
.cal-nav { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
.cal-nav-btn {
  background:white; border:1px solid var(--beige-dark);
  border-radius:var(--radius-sm); padding:7px 14px;
  font-size:13px; font-weight:500; color:var(--text-mid);
  transition:all 0.15s;
}
.cal-nav-btn:hover { border-color:var(--navy); color:var(--navy); }
.cal-month-label { font-family:var(--font-display); font-size:20px; font-weight:700; color:var(--navy); }

/* Calendar view tabs */
.view-tabs { display:flex; gap:4px; background:var(--beige); border-radius:var(--radius-sm); padding:4px; margin-bottom:20px; }
.view-tab { padding:7px 16px; border-radius:6px; font-size:12px; font-weight:500; border:none; background:transparent; color:var(--text-soft); transition:all 0.15s; }
.view-tab.active { background:white; color:var(--navy); font-weight:600; box-shadow:var(--shadow-sm); }

/* ============================================================
   AGENDA LIST
   ============================================================ */
.agenda-item {
  display:flex; align-items:flex-start; gap:16px;
  padding:14px 0; border-bottom:1px solid var(--beige-mid);
}
.agenda-item:last-child { border-bottom:none; }
.agenda-date-box {
  min-width:48px; text-align:center;
  background:var(--navy); border-radius:var(--radius-sm); padding:8px 10px; color:white;
  flex-shrink:0;
}
.agenda-date-day   { font-family:var(--font-display); font-size:20px; font-weight:700; color:var(--gold-light); line-height:1; }
.agenda-date-month { font-family:var(--font-mono); font-size:8px; letter-spacing:1px; text-transform:uppercase; color:rgba(255,255,255,0.45); }
.agenda-content { flex:1; }
.agenda-title { font-size:14px; font-weight:600; color:var(--navy); margin-bottom:3px; }
.agenda-meta  { font-size:12px; color:var(--text-soft); display:flex; gap:12px; flex-wrap:wrap; }
.agenda-dot   { width:8px; height:8px; border-radius:50%; flex-shrink:0; margin-top:5px; }

/* ============================================================
   SOLICITUD CARDS
   ============================================================ */
.solicitud-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:16px; }
.solicitud-card {
  background:white; border:1px solid var(--beige-dark);
  border-radius:var(--radius-md); box-shadow:var(--shadow-sm);
  overflow:hidden; transition:box-shadow 0.2s, transform 0.2s;
}
.solicitud-card:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
.solicitud-card-top {
  padding:16px 18px 12px;
  border-bottom:1px solid var(--beige-mid);
  display:flex; align-items:flex-start; justify-content:space-between; gap:10px;
}
.solicitud-card-title { font-size:14px; font-weight:700; color:var(--navy); line-height:1.3; }
.solicitud-card-body  { padding:12px 18px; display:flex; flex-direction:column; gap:8px; }
.solicitud-row { display:flex; align-items:center; justify-content:space-between; font-size:12px; }
.solicitud-row-label { color:var(--text-soft); }
.solicitud-row-val   { font-weight:500; color:var(--text-dark); }
.solicitud-card-footer { padding:10px 18px; border-top:1px solid var(--beige-mid); display:flex; align-items:center; justify-content:space-between; }
.btn-detail {
  padding:5px 14px; border-radius:var(--radius-sm);
  background:var(--navy); color:var(--gold-light);
  border:none; font-size:11px; font-weight:600;
  transition:all 0.15s; display:flex; align-items:center; gap:5px;
}
.btn-detail:hover { background:var(--navy-light); }

/* ============================================================
   PRIORITY INDICATOR
   ============================================================ */
.priority-dot { width:8px; height:8px; border-radius:50%; display:inline-block; flex-shrink:0; }
.priority-dot.alta    { background:var(--danger); }
.priority-dot.media   { background:var(--warn); }
.priority-dot.baja    { background:var(--success); }
.priority-dot.critica { background:#7c3aed; }
.priority-row { display:flex; align-items:center; gap:6px; font-size:12px; }

/* ============================================================
   TRAINER PROFILE CARDS
   ============================================================ */
.trainer-card {
  background:white; border:1px solid var(--beige-dark);
  border-radius:var(--radius-lg); box-shadow:var(--shadow-sm);
  overflow:hidden; transition:all 0.2s;
}
.trainer-card:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
.trainer-card-top {
  background:linear-gradient(135deg, var(--navy), var(--navy-mid));
  padding:24px 20px; text-align:center; position:relative;
}
.trainer-avatar {
  width:68px; height:68px; border-radius:50%;
  background:linear-gradient(135deg, var(--gold), #a67c28);
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:24px; font-weight:700; color:white;
  border:3px solid rgba(201,168,76,0.3);
  margin:0 auto 10px;
}
.trainer-name { font-family:var(--font-display); font-size:16px; font-weight:700; color:white; margin-bottom:3px; }
.trainer-role { font-size:12px; color:rgba(255,255,255,0.5); }
.trainer-card-body { padding:16px 20px; }
.trainer-stat-row { display:flex; gap:12px; margin-bottom:14px; }
.trainer-stat { flex:1; text-align:center; }
.trainer-stat-val { font-family:var(--font-display); font-size:20px; font-weight:700; color:var(--navy); }
.trainer-stat-lbl { font-size:10px; color:var(--text-soft); }
.trainer-tags  { display:flex; flex-wrap:wrap; gap:5px; margin-bottom:12px; }
.trainer-tag   { padding:3px 9px; border-radius:20px; font-size:10px; font-weight:600; background:var(--beige); color:var(--text-mid); font-family:var(--font-mono); }
.trainer-load  { margin-top:10px; }
.trainer-load-label { display:flex; justify-content:space-between; margin-bottom:5px; font-size:11px; color:var(--text-soft); }

/* ============================================================
   REPORT CHARTS (CSS)
   ============================================================ */
.bar-chart { display:flex; align-items:flex-end; gap:10px; height:120px; padding:0 4px; }
.bar-item  { display:flex; flex-direction:column; align-items:center; gap:5px; flex:1; }
.bar-fill  { width:100%; max-width:40px; background:linear-gradient(180deg,var(--gold),var(--gold-light)); border-radius:4px 4px 0 0; transition:height 1s ease; min-height:4px; }
.bar-label { font-family:var(--font-mono); font-size:9px; color:var(--text-soft); text-align:center; }
.bar-val   { font-family:var(--font-mono); font-size:10px; color:var(--navy); font-weight:600; }

/* Donut chart via conic-gradient */
.donut-wrap { display:flex; align-items:center; gap:24px; }
.donut {
  width:96px; height:96px; border-radius:50%; flex-shrink:0;
  background:conic-gradient(var(--gold) 0% 42%, var(--success) 42% 68%, var(--info) 68% 85%, var(--warn) 85% 100%);
  position:relative;
}
.donut::after {
  content:''; position:absolute; inset:20px;
  background:white; border-radius:50%;
}
.donut-legend { display:flex; flex-direction:column; gap:7px; }
.donut-legend-item { display:flex; align-items:center; gap:8px; font-size:12px; }
.donut-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

/* ============================================================
   TIMELINE
   ============================================================ */
.timeline { position:relative; padding-left:24px; }
.timeline::before { content:''; position:absolute; left:0; top:0; bottom:0; width:2px; background:var(--beige-dark); }
.timeline-item { position:relative; padding-bottom:20px; }
.timeline-item::before {
  content:''; position:absolute; left:-29px; top:3px;
  width:12px; height:12px; border-radius:50%;
  background:var(--gold); border:2px solid var(--gold-pale);
}
.timeline-item.done::before  { background:var(--success); border-color:var(--success-bg); }
.timeline-item.alert::before { background:var(--warn); border-color:var(--warn-bg); }
.timeline-item.late::before  { background:var(--danger); border-color:var(--danger-bg); }
.timeline-date  { font-family:var(--font-mono); font-size:10px; color:var(--text-soft); margin-bottom:3px; }
.timeline-title { font-size:13px; font-weight:600; color:var(--navy); margin-bottom:2px; }
.timeline-meta  { font-size:11px; color:var(--text-soft); }

/* ============================================================
   WORKLOAD INDICATOR
   ============================================================ */
.workload-bar { height:8px; border-radius:4px; overflow:hidden; background:var(--beige-mid); }
.workload-fill { height:100%; border-radius:4px; transition:width 0.8s ease; }
.workload-fill.low    { background:var(--success); }
.workload-fill.mid    { background:var(--warn); }
.workload-fill.high   { background:var(--danger); }
.workload-fill.crit   { background:#7c3aed; }

/* ============================================================
   SECTION TABS
   ============================================================ */
.section-tabs { display:flex; gap:0; border-bottom:2px solid var(--beige-dark); margin-bottom:24px; }
.stab {
  padding:10px 20px; font-size:13px; font-weight:500;
  border:none; background:transparent; color:var(--text-soft);
  border-bottom:2px solid transparent; margin-bottom:-2px;
  transition:all 0.15s; cursor:pointer;
}
.stab:hover { color:var(--navy); }
.stab.active { color:var(--navy); border-bottom-color:var(--gold); font-weight:700; }

/* ============================================================
   MATERIAL ITEM
   ============================================================ */
.material-item {
  display:flex; align-items:center; gap:14px;
  padding:13px 0; border-bottom:1px solid var(--beige-mid);
}
.material-item:last-child { border-bottom:none; }
.material-icon {
  width:38px; height:38px; border-radius:var(--radius-sm);
  display:flex; align-items:center; justify-content:center;
  font-size:16px; flex-shrink:0;
}
.material-icon.html  { background:#dbeafe; }
.material-icon.pdf   { background:#fde8e8; }
.material-icon.pptx  { background:#fff0e6; }
.material-icon.guide { background:#e6f4ea; }
.material-icon.sim   { background:var(--gold-pale); }
.material-icon.check { background:var(--success-bg); }
.material-content { flex:1; min-width:0; }
.material-name    { font-size:13px; font-weight:600; color:var(--navy); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.material-meta    { font-size:11px; color:var(--text-soft); display:flex; gap:10px; margin-top:2px; flex-wrap:wrap; }
.material-actions { display:flex; gap:6px; flex-shrink:0; }
.mat-btn {
  padding:4px 10px; border-radius:var(--radius-sm);
  border:1px solid var(--beige-dark); background:white;
  font-size:11px; color:var(--text-mid); font-weight:500;
  transition:all 0.15s;
}
.mat-btn:hover { border-color:var(--navy); color:var(--navy); }

/* ============================================================
   SCROLLBAR
   ============================================================ */
::-webkit-scrollbar { width:6px; height:6px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(--beige-dark); border-radius:3px; }
::-webkit-scrollbar-thumb:hover { background:var(--text-soft); }

/* ============================================================
   LOGIN SCREEN
   ============================================================ */
#login-screen {
  position:fixed; inset:0; z-index:9000;
  background:var(--navy);
  display:flex; align-items:center; justify-content:center;
  padding:24px;
}
#login-screen.hidden { display:none !important; }
.login-box { width:100%; max-width:420px; }
.login-logo {
  font-family:var(--font-display); font-size:38px; font-weight:900;
  color:var(--gold-light); margin-bottom:4px;
}
.login-logo span { color:white; }
.login-portal-tag {
  font-family:var(--font-mono); font-size:10px; color:rgba(255,255,255,0.3);
  letter-spacing:4px; text-transform:uppercase; margin-bottom:36px;
}
.login-card {
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:var(--radius-lg); padding:28px;
}
.login-card-title { font-size:18px; font-weight:700; color:white; margin-bottom:4px; }
.login-card-sub   { font-size:13px; color:rgba(255,255,255,0.4); margin-bottom:24px; }
.login-label {
  display:block; font-size:11px; font-weight:600;
  color:rgba(255,255,255,0.5); letter-spacing:.5px;
  text-transform:uppercase; margin-bottom:6px;
}
.login-input {
  width:100%; padding:12px 16px;
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.12);
  border-radius:var(--radius-sm); color:white;
  font-size:14px; font-family:var(--font-body);
  transition:border-color .2s; margin-bottom:14px;
}
.login-input::placeholder { color:rgba(255,255,255,0.25); }
.login-input:focus { outline:none; border-color:var(--gold); background:rgba(255,255,255,0.1); }
.login-btn {
  width:100%; padding:13px;
  background:var(--gold); color:var(--navy);
  border:none; border-radius:var(--radius-sm);
  font-size:14px; font-weight:700;
  font-family:var(--font-body); cursor:pointer;
  transition:all .2s; margin-top:4px;
  letter-spacing:.3px;
}
.login-btn:hover { background:var(--gold-light); transform:translateY(-1px); box-shadow:var(--shadow-gold); }
.login-error {
  background:rgba(198,40,40,.2); border:1px solid rgba(198,40,40,.35);
  color:#ef9a9a; padding:10px 14px; border-radius:var(--radius-sm);
  font-size:13px; margin-top:12px;
}
.login-inactive {
  background:rgba(180,83,9,.2); border:1px solid rgba(180,83,9,.35);
  color:#fcd34d; padding:10px 14px; border-radius:var(--radius-sm);
  font-size:13px; margin-top:12px;
}
.login-footer {
  margin-top:20px; text-align:center;
  font-size:11px; color:rgba(255,255,255,0.2);
  font-family:var(--font-mono); letter-spacing:1px;
}

/* ============================================================
   USERS SECTION
   ============================================================ */
.user-row-avatar {
  width:32px; height:32px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:12px; font-weight:700;
  color:white; flex-shrink:0;
}
.role-badge-admin  { background:#0d1b2a; color:var(--gold-light); }
.role-badge-manager { background:#1d4ed8; color:white; }
.role-badge-coordinadora { background:#7c3aed; color:white; }
.role-badge-trainer { background:var(--success); color:white; }
.toggle-switch {
  position:relative; width:40px; height:22px; display:inline-block;
}
.toggle-switch input { opacity:0; width:0; height:0; }
.toggle-slider {
  position:absolute; cursor:pointer; inset:0;
  background:#ccc; border-radius:22px; transition:.3s;
}
.toggle-slider::before {
  content:''; position:absolute;
  width:16px; height:16px; left:3px; bottom:3px;
  background:white; border-radius:50%; transition:.3s;
}
.toggle-switch input:checked + .toggle-slider { background:var(--success); }
.toggle-switch input:checked + .toggle-slider::before { transform:translateX(18px); }
.user-action-btn {
  padding:5px 10px; border-radius:var(--radius-sm);
  border:1px solid var(--beige-dark); background:white;
  font-size:11px; color:var(--text-mid); font-weight:500;
  cursor:pointer; transition:all .15s;
}
.user-action-btn:hover { border-color:var(--navy); color:var(--navy); }
.user-action-btn.danger:hover { border-color:var(--danger); color:var(--danger); background:var(--danger-bg); }
/* Access denied overlay */
.access-denied {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  height:calc(100vh - 64px); color:var(--text-soft); text-align:center; padding:24px;
}
.access-denied-icon { font-size:48px; margin-bottom:16px; }
.access-denied-title { font-family:var(--font-display); font-size:22px; font-weight:700; color:var(--navy); margin-bottom:8px; }

   Trainers: Mariana · Andrea · Joham · Diego · Nidia · Karen · Sofia · Brenda
   ============================================================ */
#section-calendario { overflow:hidden; }
#cal-embed {
  display:flex;
  height:calc(100vh - var(--header-h));
  overflow:hidden;
  background:#f0f2f7;
}
/* Cal sidebar */
#cal-embed .cal-sb {
  width:252px; flex-shrink:0;
  background:#fff; border-right:1px solid #e4e8f0;
  display:flex; flex-direction:column; gap:0;
  overflow-y:auto; overflow-x:hidden;
  scrollbar-width:thin; scrollbar-color:#e4e8f0 transparent;
}
#cal-embed .cal-sb > div { border-bottom:1px solid #e4e8f0; }
#cal-embed .cal-sb > div:last-child { border-bottom:none; }
#cal-embed .csec-title {
  font-size:10px; font-weight:700; letter-spacing:1.2px;
  text-transform:uppercase; color:#7b8aab;
  padding:10px 13px; margin-bottom:0;
  display:flex; align-items:center; justify-content:space-between;
  cursor:pointer; user-select:none; transition:background .15s;
}
#cal-embed .csec-title:hover { background:#f8f9fc; color:#3d4b63; }
#cal-embed .csec-chevron {
  font-size:9px; color:#c0c8d8; transition:transform .25s ease;
}
#cal-embed .csec-chevron.closed { transform:rotate(-90deg); }
#cal-embed .cal-acc-body {
  overflow:hidden; transition:max-height .3s ease, opacity .2s ease, padding .25s ease;
  max-height:800px; opacity:1; padding:0 13px 12px;
}
#cal-embed .cal-acc-body.closed { max-height:0 !important; opacity:0; padding-bottom:0; }
#cal-embed .c-kpi-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
#cal-embed .c-kpi-card {
  background:#f8f9fc; border:1px solid #e4e8f0;
  border-radius:10px; padding:9px 8px; text-align:center;
}
#cal-embed .c-kpi-num { font-size:20px; font-weight:700; color:#1c4ed8; line-height:1; }
#cal-embed .c-kpi-label { font-size:10.5px; color:#7b8aab; margin-top:3px; line-height:1.3; }
/* trainer rows */
#cal-embed .c-trainer-row {
  display:flex; align-items:center; gap:8px;
  padding:4px 6px; border-radius:8px; margin-bottom:2px;
}
#cal-embed .c-trainer-dot {
  width:10px; height:10px; border-radius:50%; flex-shrink:0;
}
#cal-embed .c-trainer-name { font-size:13px; font-weight:500; flex:1; color:#3d4b63; }
#cal-embed .c-trainer-count {
  font-size:11px; font-weight:600; font-family:'DM Mono',monospace;
  color:#7b8aab; background:#f8f9fc;
  padding:2px 7px; border-radius:12px; border:1px solid #e4e8f0;
}
#cal-embed .c-wbar { height:3px; border-radius:2px; background:#e4e8f0; overflow:hidden; margin-top:3px; }
#cal-embed .c-wbar-fill { height:100%; border-radius:2px; }
/* legend */
#cal-embed .c-legend-item {
  display:flex; align-items:center; gap:8px;
  padding:2px 4px; font-size:12px; color:#3d4b63;
}
#cal-embed .c-legend-sw {
  width:12px; height:12px; border-radius:3px; flex-shrink:0;
}
/* filter selects inside cal */
#cal-embed select.c-filter {
  width:100%; padding:7px 10px; border-radius:8px;
  border:1px solid #d0d6e4; font-family:inherit;
  font-size:12.5px; color:#3d4b63; background:#f8f9fc;
  cursor:pointer; appearance:none; margin-bottom:7px;
}
#cal-embed select.c-filter:focus { outline:none; border-color:#1c4ed8; }
/* upcoming items */
#cal-embed .c-upc-item {
  border-left:3px solid; padding:7px 8px;
  border-radius:0 8px 8px 0; margin-bottom:5px;
  background:#f8f9fc; cursor:pointer; transition:all .15s;
}
#cal-embed .c-upc-item:hover { transform:translateX(2px); }
#cal-embed .c-upc-title { font-size:12.5px; font-weight:600; color:#0f1623; }
#cal-embed .c-upc-meta  { font-size:11px; color:#7b8aab; margin-top:2px; }
/* vac / bday items */
#cal-embed .c-vac-item, #cal-embed .c-bday-item, #cal-embed .c-off-item {
  display:flex; align-items:center; gap:7px;
  padding:5px 8px; border-radius:8px;
  background:#f8f9fc; margin-bottom:4px; cursor:pointer;
  transition:all .15s; border:1px solid #e4e8f0;
}
#cal-embed .c-vac-item:hover, #cal-embed .c-bday-item:hover, #cal-embed .c-off-item:hover {
  transform:translateX(2px);
}
#cal-embed .c-name-label { font-size:12.5px; font-weight:700; flex:1; }
#cal-embed .c-date-label { font-size:11px; color:#7b8aab; }
#cal-embed .c-bday-days {
  font-size:10px; padding:2px 6px; border-radius:10px; font-weight:700; white-space:nowrap;
}
/* sidebar clear btn */
#cal-embed .c-clear-btn {
  width:100%; padding:7px; border-radius:8px;
  border:1px dashed #d0d6e4; background:transparent;
  color:#7b8aab; font-size:12.5px; font-family:inherit;
  cursor:pointer; transition:all .15s;
}
#cal-embed .c-clear-btn:hover { border-color:#1c4ed8; color:#1c4ed8; }
/* Main area */
#cal-embed .cal-main {
  flex:1; min-width:0;
  display:flex; flex-direction:column;
  overflow:hidden; padding:16px;
}
/* top action bar */
#cal-embed .cal-action-bar {
  display:flex; align-items:center; gap:10px;
  margin-bottom:12px; flex-wrap:wrap; flex-shrink:0;
}
#cal-embed .c-btn {
  display:inline-flex; align-items:center; gap:6px;
  padding:8px 16px; border-radius:10px;
  font-family:inherit; font-size:13px; font-weight:600;
  cursor:pointer; border:none; transition:all .18s; white-space:nowrap;
}
#cal-embed .c-btn-primary { background:#1c4ed8; color:#fff; }
#cal-embed .c-btn-primary:hover { background:#1e40af; box-shadow:0 3px 12px rgba(28,78,216,.35); transform:translateY(-1px); }
#cal-embed .c-btn-ghost { background:#fff; color:#3d4b63; border:1px solid #d0d6e4; }
#cal-embed .c-btn-ghost:hover { background:#f8f9fc; }
#cal-embed .c-btn-sm { padding:6px 12px; font-size:12px; }
/* view tabs */
#cal-embed .c-view-tabs {
  display:flex; gap:4px; background:#e4e8f0; border-radius:10px;
  padding:4px; margin-bottom:12px; flex-shrink:0;
  border:1px solid #e4e8f0;
}
#cal-embed .c-view-tab {
  flex:1; padding:7px 14px; border:none; cursor:pointer;
  border-radius:7px; font-size:13px; font-weight:600;
  background:transparent; color:#7b8aab; transition:all .2s;
  display:flex; align-items:center; justify-content:center; gap:5px;
}
#cal-embed .c-view-tab.active {
  background:#fff; color:#0f1623;
  box-shadow:0 1px 4px rgba(0,0,0,.1);
}
#cal-embed .c-view-tab.active.el { color:#6366f1; }
/* FullCalendar wrapper */
#cal-embed #calPanel {
  flex:1; min-height:0;
  display:flex; flex-direction:column; overflow:hidden;
}
#cal-embed .cal-card {
  background:#fff; border:1px solid #e4e8f0;
  border-radius:16px; padding:16px;
  box-shadow:0 1px 3px rgba(15,22,35,.08);
  flex:1; min-height:0; display:flex;
  flex-direction:column; overflow:hidden;
}
#cal-embed #calendar { flex:1; min-height:0; }
/* FullCalendar overrides — namespaced to #cal-embed */
#cal-embed .fc {
  font-family:'DM Sans',sans-serif;
  --fc-border-color:#e4e8f0;
  --fc-today-bg-color:rgba(28,78,216,.05);
  flex:1; min-height:0;
}
#cal-embed .fc-toolbar-title { font-size:18px !important; font-weight:700 !important; color:#0f1623 !important; }
#cal-embed .fc-button {
  background:#f8f9fc !important; border:1px solid #d0d6e4 !important;
  color:#3d4b63 !important; border-radius:8px !important;
  font-family:'DM Sans',sans-serif !important;
  font-size:12.5px !important; font-weight:600 !important;
  padding:6px 12px !important; text-transform:capitalize !important;
  box-shadow:none !important;
}
#cal-embed .fc-button:hover { background:#e4e8f0 !important; color:#0f1623 !important; }
#cal-embed .fc-button-primary:not(:disabled).fc-button-active,
#cal-embed .fc-button-primary:not(:disabled):active {
  background:#1c4ed8 !important; border-color:#1c4ed8 !important; color:#fff !important;
}
#cal-embed .fc-event {
  border-radius:5px !important; padding:0 !important;
  cursor:pointer !important; transition:transform .12s, box-shadow .12s;
  font-size:11.5px !important; font-weight:500 !important; border:none !important;
}
#cal-embed .fc-event:hover {
  transform:translateY(-1px);
  box-shadow:0 3px 10px rgba(0,0,0,.25) !important;
  filter:brightness(1.08);
}
#cal-embed .fc-daygrid-event { display:flex !important; border-radius:5px !important; overflow:hidden !important; margin-bottom:2px !important; }
#cal-embed .fc-daygrid-event-dot { display:none !important; }
#cal-embed .fc-daygrid-event .fc-event-main { flex:1 !important; min-width:0 !important; padding:0 !important; }
#cal-embed .fc-daygrid-block-event .fc-event-main { padding:0 !important; }
#cal-embed .fc-col-header-cell-cushion { font-weight:600 !important; color:#3d4b63; font-size:12px; }
#cal-embed .fc-daygrid-day-number { color:#3d4b63 !important; font-size:12.5px !important; font-weight:500; }
#cal-embed .fc-timegrid-slot-label { font-size:10.5px !important; color:#7b8aab; }
#cal-embed .fc-toolbar { margin-bottom:12px !important; }
/* Tooltip */
#cal-embed .ev-tooltip {
  display:none; position:absolute; z-index:300;
  background:#0f1623; color:#fff; padding:10px 13px;
  border-radius:10px; font-size:11.5px; line-height:1.55;
  max-width:240px; pointer-events:none; box-shadow:0 8px 24px rgba(0,0,0,.35);
  top:calc(100% + 6px); left:0;
}
#cal-embed .fc-event:hover .ev-tooltip { display:block; }
/* Banner events (vacaciones / cumpleaños / OFF) */
#cal-embed .fc-banner-vac { background:linear-gradient(90deg,#f59e0b,#fbbf24) !important; border:none !important; border-radius:4px !important; color:#fff !important; font-weight:700 !important; font-size:11px !important; }
#cal-embed .fc-banner-bday { background:linear-gradient(90deg,#ec4899,#f472b6) !important; border:none !important; border-radius:4px !important; color:#fff !important; font-weight:700 !important; font-size:11px !important; }
#cal-embed .fc-banner-off { background:repeating-linear-gradient(45deg,#94a3b8,#94a3b8 4px,#cbd5e1 4px,#cbd5e1 10px) !important; border:none !important; border-radius:4px !important; color:#1e293b !important; font-weight:700 !important; font-size:11px !important; opacity:.85 !important; }
#cal-embed .fc-day-off { background:rgba(148,163,184,.12) !important; }
/* E-Learning panel */
#cal-embed #elPanel {
  flex:1; min-height:0; display:none;
  flex-direction:column; overflow:hidden; gap:10px;
}
#cal-embed .el-split {
  flex:1; min-height:0; display:grid;
  grid-template-columns:1fr 1fr; gap:12px; overflow:hidden;
}
#cal-embed .el-cal-wrap {
  background:#fff; border:1px solid #e4e8f0;
  border-radius:12px; padding:14px;
  display:flex; flex-direction:column; min-height:0; overflow:hidden;
}
#cal-embed .el-cal-wrap .fc { flex:1; min-height:0; }
#cal-embed .el-list-wrap { display:flex; flex-direction:column; min-height:0; overflow:hidden; gap:8px; }
#cal-embed .el-kpi-row { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; flex-shrink:0; }
#cal-embed .el-kpi {
  background:#fff; border:1px solid #e4e8f0;
  border-radius:10px; padding:12px 14px; text-align:center;
}
#cal-embed .el-kpi-num { font-size:24px; font-weight:800; color:#6366f1; font-family:'DM Mono',monospace; }
#cal-embed .el-kpi-label { font-size:10.5px; color:#7b8aab; margin-top:2px; font-weight:600; }
#cal-embed .el-table-wrap { background:#fff; border:1px solid #e4e8f0; border-radius:12px; overflow:auto; flex:1; min-height:0; }
#cal-embed .el-table { width:100%; border-collapse:collapse; }
#cal-embed .el-table th { background:#f8f9fc; padding:10px 12px; font-size:10.5px; font-weight:700; color:#7b8aab; text-transform:uppercase; letter-spacing:.04em; border-bottom:1px solid #e4e8f0; text-align:left; white-space:nowrap; }
#cal-embed .el-table td { padding:10px 12px; font-size:12.5px; border-bottom:1px solid #e4e8f0; vertical-align:middle; }
#cal-embed .el-table tr:last-child td { border-bottom:none; }
#cal-embed .el-table tr:hover td { background:#f8f9fc; }
#cal-embed .el-status { display:inline-block; padding:3px 9px; border-radius:20px; font-size:10.5px; font-weight:700; }
#cal-embed .el-status.pendiente   { background:#fef3c7; color:#92400e; }
#cal-embed .el-status.en-revision { background:#dbeafe; color:#1e40af; }
#cal-embed .el-status.completado  { background:#d1fae5; color:#065f46; }
#cal-embed .el-status.cancelado   { background:#fee2e2; color:#991b1b; }
#cal-embed .el-empty { text-align:center; padding:40px 20px; color:#7b8aab; font-size:13.5px; }
#cal-embed .el-empty-icon { font-size:34px; margin-bottom:8px; }
#cal-embed .el-link-btn {
  display:inline-flex; align-items:center; gap:4px; padding:3px 9px;
  border-radius:6px; font-size:11px; font-weight:600;
  background:#eef2ff; color:#6366f1; text-decoration:none;
  border:1px solid #c7d2fe; transition:all .15s;
}
#cal-embed .el-link-btn:hover { background:#e0e7ff; }
#cal-embed .el-btn-icon {
  padding:4px 7px; border:1px solid #e4e8f0;
  border-radius:6px; background:#fff; cursor:pointer;
  font-size:12px; transition:all .15s; line-height:1;
}
#cal-embed .el-btn-icon:hover { background:#f8f9fc; }
#cal-embed .el-btn-icon.danger:hover { background:#fee2e2; border-color:#fca5a5; }
#cal-embed .el-actions { display:flex; gap:5px; }
#cal-embed .el-filters { display:flex; gap:8px; align-items:center; flex-wrap:wrap; flex-shrink:0; }
#cal-embed .el-filters select, #cal-embed .el-filters input {
  padding:6px 10px; border:1px solid #e4e8f0;
  border-radius:8px; font-size:12px; color:#0f1623;
  background:#fff; outline:none;
}
#cal-embed .el-filters select:focus, #cal-embed .el-filters input:focus {
  border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.1);
}
#cal-embed .el-top-bar {
  display:flex; align-items:center; justify-content:space-between;
  gap:10px; flex-shrink:0;
}
/* ── LIVE INDICATOR ── */
.live-dot {
  display:inline-flex; align-items:center; gap:5px;
  font-family:var(--font-mono); font-size:10px;
  color:var(--text-soft); white-space:nowrap;
}
.live-dot::before {
  content:'';
  width:7px; height:7px; border-radius:50%;
  background:var(--success);
  animation:livePulse 2s ease-in-out infinite;
  flex-shrink:0;
}
.live-dot.syncing::before { background:var(--gold); animation:none; }
.live-dot.offline::before { background:var(--locked); animation:none; }
@keyframes livePulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:.4; transform:scale(.85); }
}

.rev-card {
  background:white; border:1px solid var(--beige-dark);
  border-radius:var(--radius-md); box-shadow:var(--shadow-sm);
  overflow:hidden; transition:box-shadow .2s, transform .2s;
  display:flex; flex-direction:column;
}
.rev-card:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
.rev-card-header {
  padding:14px 16px 10px;
  border-bottom:1px solid var(--beige-mid);
  display:flex; align-items:flex-start; gap:10px;
}
.rev-card-title  { font-size:14px; font-weight:700; color:var(--navy); line-height:1.3; flex:1; }
.rev-card-body   { padding:10px 16px; display:flex; flex-direction:column; gap:7px; flex:1; }
.rev-card-row    { display:flex; align-items:center; justify-content:space-between; font-size:12px; }
.rev-card-label  { color:var(--text-soft); }
.rev-card-val    { font-weight:500; color:var(--text-dark); }
.rev-card-footer {
  padding:10px 16px; border-top:1px solid var(--beige-mid);
  display:flex; gap:7px; flex-wrap:wrap; align-items:center;
}
/* Revisora action buttons */
.rev-btn-take   { background:#1d4ed8; color:white; border:none; border-radius:var(--radius-sm); padding:6px 12px; font-size:11px; font-weight:600; cursor:pointer; transition:all .15s; }
.rev-btn-take:hover   { background:#1e40af; }
.rev-btn-obs    { background:var(--warn-bg); color:var(--warn); border:1px solid #fcd34d; border-radius:var(--radius-sm); padding:6px 12px; font-size:11px; font-weight:600; cursor:pointer; transition:all .15s; }
.rev-btn-obs:hover    { background:#fde68a; }
.rev-btn-approve{ background:var(--success-bg); color:var(--success); border:1px solid #86efac; border-radius:var(--radius-sm); padding:6px 12px; font-size:11px; font-weight:600; cursor:pointer; transition:all .15s; }
.rev-btn-approve:hover{ background:#bbf7d0; }
.rev-btn-upload { background:var(--navy); color:var(--gold-light); border:none; border-radius:var(--radius-sm); padding:6px 12px; font-size:11px; font-weight:600; cursor:pointer; transition:all .15s; }
.rev-btn-upload:hover { background:var(--navy-light); }
/* Trainer action buttons */
.rev-btn-update { background:var(--gold-pale); color:#8b6914; border:1px solid var(--gold); border-radius:var(--radius-sm); padding:6px 12px; font-size:11px; font-weight:600; cursor:pointer; transition:all .15s; }
.rev-btn-update:hover { background:var(--gold); color:var(--navy); }
/* Status accent bar */
.rev-card.status-nueva          { border-top:3px solid var(--gold); }
.rev-card.status-en-revision    { border-top:3px solid var(--info); }
.rev-card.status-observaciones  { border-top:3px solid var(--warn); }
.rev-card.status-modificaciones { border-top:3px solid #6366f1; }
.rev-card.status-aprobada       { border-top:3px solid var(--success); }
.rev-card.status-subir          { border-top:3px solid var(--navy); }
.rev-card.status-completada     { border-top:3px solid #94a3b8; }
/* Link pill */
.rev-link-pill {
  display:inline-flex; align-items:center; gap:5px;
  padding:3px 10px; border-radius:20px;
  background:#eef2ff; color:#4f46e5;
  border:1px solid #c7d2fe; font-size:11px; font-weight:600;
  text-decoration:none; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
  transition:all .15s;
}
.rev-link-pill:hover { background:#e0e7ff; }
/* Historial timeline inside modal */
.rev-historial-item {
  display:flex; gap:12px; padding:8px 0;
  border-bottom:1px solid var(--beige-mid); font-size:12px;
}
.rev-historial-item:last-child { border-bottom:none; }
.rev-hist-who  { font-weight:700; color:var(--navy); min-width:80px; }
.rev-hist-what { color:var(--text-mid); flex:1; }
.rev-hist-when { color:var(--text-soft); font-family:var(--font-mono); font-size:10px; white-space:nowrap; }
/* Trainer my-requests banner */
.rev-trainer-banner {
  background:linear-gradient(135deg,var(--navy),var(--navy-mid));
  border-radius:var(--radius-md); padding:18px 22px;
  margin-bottom:20px; display:flex; align-items:center;
  justify-content:space-between; gap:16px; flex-wrap:wrap;
}
.rev-trainer-banner-text { color:white; font-size:14px; }
.rev-trainer-banner-text strong { font-family:var(--font-display); font-size:18px; font-weight:700; display:block; margin-bottom:3px; color:var(--gold-light); }
/* Instrumento link section */
.rev-instrumento-box {
  background:var(--beige); border:1px solid var(--beige-dark);
  border-radius:var(--radius-sm); padding:12px 14px;
  margin-top:8px;
}
.accent-info { border-left:3px solid var(--info); }

/* ============================================================
   CAL-V49 — Estilos del Calendario de Trainers (v49)
   Todos los selectores prefijados con #cal-v49
   ============================================================ */
#cal-v49 {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: calc(100vh - var(--header-h, 64px));
  overflow: hidden;
  font-family: 'DM Sans', system-ui, sans-serif;
  color: #0f1623;
}
#cal-v49 .layout {
  display: grid;
  grid-template-columns: 252px 1fr;
  flex: 1;
  min-height: 0;
  width: 100%;
  overflow: hidden;
}
#cal-v49 .sidebar {
  height: 100%;
  overflow-y: auto;
}
#cal-v49 .main {
  padding: 16px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  height: 100%;
  box-sizing: border-box;
}
#cal-v49 #calPanel {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
#cal-v49 .calendar-card {
  flex: 1;
  min-height: 0;
}
#cal-v49 #calendar {
  flex: 1;
  min-height: 0;
  height: 100%;
}

    /* =========================================================
#cal-v49 DESIGN TOKENS
#cal-v49 ========================================================= */
/* :root vars from cal-v49 */
    #cal-v49 {
      --bg:         #f0f2f7;
      --surface:    #ffffff;
      --surface2:   #f8f9fc;
      --border:     #e4e8f0;
      --border-md:  #d0d6e4;
      --text-1:     #0f1623;
      --text-2:     #3d4b63;
      --text-3:     #7b8aab;
      --accent:     #1c4ed8;
      --accent-h:   #1e40af;
      --accent-lt:  #eff3ff;
      --danger:     #dc2626;
      --success:    #16a34a;
      --warning:    #d97706;
      --radius:     10px;
      --radius-lg:  16px;
      --shadow-sm:  0 1px 3px rgba(15,22,35,.08), 0 1px 2px rgba(15,22,35,.04);
      --shadow-md:  0 4px 16px rgba(15,22,35,.10), 0 2px 6px rgba(15,22,35,.06);
      --shadow-lg:  0 12px 40px rgba(15,22,35,.14), 0 4px 12px rgba(15,22,35,.08);

      /* Trainer palette — editar aquí para añadir trainers */
      --c-mariana:  #5b8ff9;
      --c-andrea:   #34c471;
      --c-joham:    #9f6ef5;
      --c-diego:    #22b4d6;
      --c-nidia:    #f5823e;
      --c-karen:    #f056a0;
      --c-sofia:    #84cc16;
      --c-brenda:   #f59e0b;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

#cal-v49 {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
    }

    /* =========================================================
#cal-v49 TOPBAR
#cal-v49 ========================================================= */
#cal-v49 .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 60px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow-sm);
    }
#cal-v49 .topbar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      font-size: 15px;
      color: var(--text-1);
      white-space: nowrap;
    }
#cal-v49 .topbar-logo .badge {
      background: var(--accent);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 20px;
      letter-spacing: .5px;
      text-transform: uppercase;
    }
#cal-v49 .topbar-sep { width: 1px; height: 28px; background: var(--border); }
#cal-v49 .topbar-sub { color: var(--text-3); font-size: 13px; }
#cal-v49 .topbar-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; }

    /* =========================================================
#cal-v49 BUTTONS
#cal-v49 ========================================================= */
#cal-v49 .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 16px; border-radius: var(--radius);
      font-family: inherit; font-size: 13.5px; font-weight: 600;
      cursor: pointer; border: none; transition: all .18s; white-space: nowrap;
    }
#cal-v49 .btn-primary {
      background: var(--accent); color: #fff;
    }
#cal-v49 .btn-primary:hover { background: var(--accent-h); box-shadow: 0 3px 12px rgba(28,78,216,.35); transform: translateY(-1px); }
#cal-v49 .btn-ghost {
      background: transparent; color: var(--text-2); border: 1px solid var(--border-md);
    }
#cal-v49 .btn-ghost:hover { background: var(--surface2); border-color: var(--border-md); }
#cal-v49 .btn-danger { background: var(--danger); color: #fff; }
#cal-v49 .btn-danger:hover { background: #b91c1c; }
