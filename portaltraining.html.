// ── Render Kanban ─────────────────────────────────────────
function renderDiPipeline() {
  const cols = {
    'Abierto':     document.getElementById('di-col-abierto'),
    'En proceso':  document.getElementById('di-col-proceso'),
    'En revisión': document.getElementById('di-col-revision'),
    'Confirmado':  document.getElementById('di-col-confirmado'),
  };
  const counts = { 'Abierto':0,'En proceso':0,'En revisión':0,'Confirmado':0 };

  Object.values(cols).forEach(c => { if(c) c.innerHTML = ''; });

  diTickets.forEach(t => {
    const col = cols[t.estatus];
    if (!col) return;
    counts[t.estatus]++;

    const hoy     = new Date(); hoy.setHours(0,0,0,0);
    const lim     = t.fechaLim ? new Date(t.fechaLim + 'T00:00:00') : null;
    const diasRest = lim ? Math.round((lim - hoy) / 86400000) : null;
    const deadlineCls = diasRest === 0 ? 'vence-hoy' : diasRest !== null && diasRest <= 3 ? 'vence-pronto' : '';
    const deadlineTxt = diasRest === null ? '' :
      diasRest < 0  ? `⚠️ Vencido hace ${Math.abs(diasRest)}d` :
      diasRest === 0 ? '🔴 Vence hoy' :
      `📅 ${diasRest}d restantes`;

    const tipoCls  = { 'Creación':'tipo-creacion','Revisión':'tipo-revision','Actualización':'tipo-actualizacion' }[t.tipo] || '';
    const prioCls  = { 'Alta':'prio-alta','Media':'prio-media','Baja':'prio-baja' }[t.prioridad] || '';
    const nAvances = (t.avances || []).length;

    col.innerHTML += `
      <div class="di-card" onclick="openDiModal('${t.id}')">
        <div class="di-card-title">${t.title}</div>
        <div class="di-card-meta">
          <span>👤 ${t.trainer}</span>
          <span><span class="di-badge ${tipoCls}">${t.tipo}</span></span>
          <span><span class="di-badge ${prioCls}">${t.prioridad}</span></span>
          ${t.area ? `<span>📁 ${t.area}</span>` : ''}
          ${nAvances ? `<span>💬 ${nAvances}</span>` : ''}
          ${t.link ? `<span><a href="${t.link}" target="_blank" rel="noopener" onclick="event.stopPropagation()" style="color:var(--accent);font-weight:600">🔗 Ver</a></span>` : ''}
        </div>
        ${deadlineTxt ? `<div class="di-deadline ${deadlineCls}" style="margin-top:5px">${deadlineTxt}</div>` : ''}
      </div>`;
  });

  // Actualizar contadores
  Object.entries(counts).forEach(([est, n]) => {
    const slug = DI_ESTATUS_SLUG[est];
    const el = document.getElementById('di-count-' + slug);
    if (el) el.textContent = n;
  });
}

