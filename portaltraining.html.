function cargaClass(n) {
  if (n >= 90) return 'crit';
  if (n >= 75) return 'high';
  if (n >= 50) return 'mid';
  return 'low';
}

/* ============================================================
   DASHBOARD RENDER
   ============================================================ */
function renderDashboard() {
  // ── Pull data from the real calendar ────────────────────────
  const now    = new Date(); now.setHours(0,0,0,0);
  const lun    = new Date(now); lun.setDate(now.getDate() - ((now.getDay()+6)%7));
  const dom    = new Date(lun); dom.setDate(lun.getDate()+6);
  const en14   = new Date(now.getTime() + 14*86400000);
  const en30   = new Date(now.getTime() + 30*86400000);

  const realEvents = calEventos.filter(e =>
    !['Vacaciones','Cumpleaños','Día OFF'].includes(e.tipoActividad)
  );
  const trainingTypes = ['Training teórico','Training práctico','Habilitación'];

  // Semana actual
  const semanaEvs   = realEvents.filter(e => { const d=calParseLocal(e.start); d.setHours(0,0,0,0); return d>=lun && d<=dom; });
  const trainingsSem= semanaEvs.filter(e  => trainingTypes.includes(e.tipoActividad));

  // Hero boxes
  const solEl = document.getElementById('hero-box-sol');
  const entEl = document.getElementById('hero-box-entregas');
  if (solEl) solEl.textContent  = SOLICITUDES.length ? SOLICITUDES.filter(s=>s.estatus!=='Completada').length : '—';
  if (entEl) entEl.textContent  = trainingsSem.length || '—';

  // KPI cards
  const mesEvs = realEvents.filter(e => {
    const d = calParseLocal(e.start);
    return d.getMonth()===now.getMonth() && d.getFullYear()===now.getFullYear();
  });
  const kpiTrain = document.getElementById('kpi-trainings-mes');
  const kpiRev   = document.getElementById('kpi-revisiones-comp');
  const kpiSol   = document.getElementById('kpi-sol-pend');
  const kpiMat   = document.getElementById('kpi-materiales');
  if (kpiTrain) kpiTrain.textContent = mesEvs.filter(e=>trainingTypes.includes(e.tipoActividad)).length || '0';
  if (kpiRev)   kpiRev.textContent   = REVISIONES.length || '0';
  if (kpiSol)   kpiSol.textContent   = SOLICITUDES.filter(s=>s.estatus!=='Completada').length || '0';
  if (kpiMat)   kpiMat.textContent   = MATERIALES.length || '0';

  // Hero stat vals
  const hTrainings  = document.getElementById('hero-stat-trainings');
  const hRevisiones = document.getElementById('hero-stat-revisiones');
  const hSolicitudes= document.getElementById('hero-stat-solicitudes');
  const hMateriales = document.getElementById('hero-stat-materiales');
  if (hTrainings)   hTrainings.textContent   = mesEvs.filter(e=>trainingTypes.includes(e.tipoActividad)).length || '0';
  if (hRevisiones)  hRevisiones.textContent  = REVISIONES.length || '0';
  if (hSolicitudes) hSolicitudes.textContent = SOLICITUDES.length || '0';
  if (hMateriales)  hMateriales.textContent  = MATERIALES.length || '0';

  // Portal sidebar status
  const sbTrain = document.getElementById('sidebar-trainings-activos');
  const sbSem   = document.getElementById('sidebar-act-semana');
  if (sbTrain) sbTrain.textContent = mesEvs.filter(e=>trainingTypes.includes(e.tipoActividad)).length || '0';
  if (sbSem)   sbSem.textContent   = semanaEvs.length || '0';

  // Pending header bubble
  const pendEl = document.getElementById('pending-count');
  const pend = SOLICITUDES.filter(s=>s.estatus!=='Completada').length;
  if (pendEl) {
    pendEl.textContent = pend;
    pendEl.style.display = pend > 0 ? '' : 'none';
  }

  // ── Próximos trainings (del calendario real) ─────────────────
  const proximos = realEvents
    .filter(e => { const d=calParseLocal(e.start); d.setHours(0,0,0,0); return d>=now && d<=en14 && trainingTypes.includes(e.tipoActividad); })
    .sort((a,b)=>calParseLocal(a.start)-calParseLocal(b.start))
    .slice(0,4);

  const listEl = document.getElementById('proximos-trainings-list');
  if (listEl) {
    if (!proximos.length) {
      listEl.innerHTML = `<div class="empty-state" style="padding:24px 0">
        <div class="empty-state-icon">📅</div>
        <div>Sin trainings en los próximos 14 días</div>
      </div>`;
    } else {
      listEl.innerHTML = proximos.map(ev => {
        const d = calParseLocal(ev.start);
        const icon = CAL_TIPOS_ICON[ev.tipoActividad]||'📌';
        const color = calTrainerColor(ev.trainer);
        const timeStr = ev.start.includes('T')
          ? d.toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'})
          : 'Todo el día';
        return `<div class="agenda-item">
          <div class="agenda-date-box">
            <div class="agenda-date-day">${d.getDate()}</div>
            <div class="agenda-date-month">${d.toLocaleDateString('es-MX',{month:'short'}).toUpperCase()}</div>
          </div>
          <div class="agenda-content">
            <div class="agenda-title">${icon} ${ev.title}</div>
            <div class="agenda-meta">
              <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;color:${color}">
                <span style="width:7px;height:7px;border-radius:50%;background:${color};flex-shrink:0"></span>${ev.trainer||'—'}
              </span>
              <span>🕐 ${timeStr}</span>
              <span>${ev.sala||''}</span>
            </div>
          </div>
        </div>`;
      }).join('');
    }
  }

  // ── Solicitudes recientes ─────────────────────────────────────
  const solListEl = document.getElementById('dashboard-solicitudes-list');
  if (solListEl) {
    if (!SOLICITUDES.length) {
      solListEl.innerHTML = `<div class="empty-state" style="padding:24px 0">
        <div class="empty-state-icon">📝</div>
        <div>Sin solicitudes registradas aún</div>
      </div>`;
    } else {
      solListEl.innerHTML = SOLICITUDES.slice(0,5).map(s => `
        <div style="display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--beige-mid)">
          <div>
            <div style="font-size:13px;font-weight:600;color:var(--navy);margin-bottom:2px">${s.titulo||s.title||'—'}</div>
            <div style="font-size:11px;color:var(--text-soft)">${s.tipo||''} · ${s.area||''}</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">
            ${statusBadge(s.estatus)}
          </div>
        </div>`).join('');
    }
  }

  // ── Estatus del equipo (desde usuarios registrados + calendario) ──
  const users    = (typeof getUsers === 'function' ? getUsers() : null) || [];
  const trainers = users.filter(u => u.rol === 'trainer' && u.activo);
  const equipoEl = document.getElementById('dashboard-equipo-table');
  if (equipoEl) {
    if (!trainers.length) {
      equipoEl.innerHTML = `<tr><td colspan="5"><div class="empty-state" style="padding:20px">Sin trainers registrados aún</div></td></tr>`;
    } else {
      equipoEl.innerHTML = trainers.map(u => {
        const count = realEvents.filter(e=>e.trainer===u.trainer).length;
        const maxCnt= Math.max(1,...trainers.map(x=>realEvents.filter(e=>e.trainer===x.trainer).length));
        const pct   = Math.round((count/maxCnt)*100);
        const cls   = pct>=80?'high':pct>=50?'mid':'low';
        const prox  = realEvents.filter(e=>{
          const d=calParseLocal(e.start);d.setHours(0,0,0,0);
          return e.trainer===u.trainer && d>=now && d<=en14;
        });
        return `<tr>
          <td>
            <div style="display:flex;align-items:center;gap:10px">
              <div style="width:30px;height:30px;border-radius:50%;background:${u.color};display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:11px;font-weight:700;color:white;flex-shrink:0">${u.iniciales}</div>
              <div>
                <div class="td-main">${u.nombre}</div>
                <div class="td-soft">${u.username}</div>
              </div>
            </div>
          </td>
          <td><span class="badge badge-green" style="font-size:10px">Trainer</span></td>
          <td class="td-soft">${prox[0]?.title || '—'}</td>
          <td><span class="badge badge-gold">${count} registros</span></td>
          <td>
            <div style="min-width:80px">
              <div style="display:flex;justify-content:space-between;font-size:10px;font-family:var(--font-mono);margin-bottom:3px">
                <span>Actividad</span><span>${count}</span>
              </div>
              <div class="workload-bar"><div class="workload-fill ${cls}" style="width:${pct}%"></div></div>
            </div>
          </td>
        </tr>`;
      }).join('');
    }
  }
}

