function startLiveRefresh() {
  // Portal sections every 5 s
  _livePortalTimer = setInterval(silentRefreshPortal, REFRESH_INTERVAL_PORTAL);

  // Calendar every 5 s check (but actual fetch only every 30 s)
  _liveCalendarTimer = setInterval(silentRefreshCalendar, REFRESH_INTERVAL_PORTAL);

  // Page visibility API — pause when tab is hidden, resume when shown
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      clearInterval(_livePortalTimer);
      clearInterval(_liveCalendarTimer);
    } else {
      _livePortalTimer   = setInterval(silentRefreshPortal,  REFRESH_INTERVAL_PORTAL);
      _liveCalendarTimer = setInterval(silentRefreshCalendar, REFRESH_INTERVAL_PORTAL);
      // Immediate refresh on tab return
      silentRefreshPortal();
      silentRefreshCalendar();
    }
  });
}
function canAccess(section) {
