/* ── LOGIN / LOGOUT ── */
function doLogin() {
  const username = document.getElementById('login-username').value.trim();
  const password = document.getElementById('login-password').value;
  document.getElementById('login-error').classList.add('hidden');
  document.getElementById('login-inactive').classList.add('hidden');

  if (!username || !password) {
    document.getElementById('login-error').classList.remove('hidden');
    return;
  }

  const users = getUsers() || DEFAULT_USERS;
  const user  = users.find(u => u.username === username && u.password === btoa(password));

  if (!user) {
    document.getElementById('login-error').classList.remove('hidden');
    return;
  }
  if (!user.activo) {
    document.getElementById('login-inactive').classList.remove('hidden');
    return;
  }

  // Update last access
  user.ultimoAcceso = new Date().toISOString();
  saveUsers(users);
  saveSession(user);

  document.getElementById('login-screen').classList.add('hidden');
  bootApp(user);
}

function doLogout() {
  clearSession();
  location.reload();
}

/* ── BOOT APP ── */
function bootApp(session) {
  const rol = session.rol;

  // Update header
  document.getElementById('header-avatar-initials').textContent = session.iniciales;
  document.getElementById('header-avatar').style.background =
    `linear-gradient(135deg, ${session.color}, ${session.color}99)`;
  document.getElementById('avatar-menu-name').textContent = '👤 ' + session.nombre;
  document.getElementById('avatar-menu-role').innerHTML =
    `<span class="badge ${ROL_BADGE[rol]||'badge-gray'}">${ROL_LABEL[rol]||rol}</span>`;

  // Show/hide role-specific menu items
  if (rol === 'admin') {
    document.getElementById('avatar-menu-usuarios').style.display = '';
    document.getElementById('nav-usuarios-wrap').style.display    = '';
  }
  if (rol === 'admin' || rol === 'manager') {
    document.getElementById('avatar-menu-manager').style.display = '';
  }

  // Update hero greeting
  const heroTitle = document.getElementById('dash-hero-greeting');
  if (heroTitle) heroTitle.textContent = session.nombre;

  // Hide sidebar items based on role
  const allowed = ROLE_SECTIONS[rol] || ROLE_SECTIONS.trainer;
  const navMap = {
    dashboard:'nav-dashboard', calendario:'nav-calendario',
    revisiones:'nav-revisiones', solicitudes:'nav-solicitudes',
    materiales:'nav-materiales', reportes:'nav-reportes',
    'panel-manager':'nav-panel-manager', equipo:'nav-equipo',
    usuarios:'nav-usuarios'
  };
  Object.entries(navMap).forEach(([section, navId]) => {
    const el = document.getElementById(navId);
    if (el) el.style.display = allowed.includes(section) ? '' : 'none';
  });

  // For trainers: pre-filter calendar to their name
  if (rol === 'trainer' && session.trainer) {
    // Will be applied when calendar loads
    window._calTrainerFilter = session.trainer;
  }

  // Set date
  const now = new Date();
  document.getElementById('header-date').textContent =
    now.toLocaleDateString('es-MX', { weekday:'short', day:'numeric', month:'short', year:'numeric' })
       .replace(/^\w/, c => c.toUpperCase());

  // Set week
  const wk = Math.ceil((now.getDate() + new Date(now.getFullYear(), now.getMonth(), 1).getDay()) / 7);
  document.getElementById('sidebar-week').textContent = 'Sem. ' + (isNaN(wk)?14:wk);

  // Render
  renderDashboard();
  renderMateriales();

  // Hide loader
  setTimeout(() => document.getElementById('loader').classList.add('fade-out'), 1900);

  // Start live auto-refresh
  startLiveRefresh();
}

/* ============================================================
   LIVE AUTO-REFRESH — Actualización en tiempo real
   ============================================================
   · Secciones de localStorage (revisiones, solicitudes):
       se refrescan cada 5 segundos — instantáneo, sin costo.
   · Calendario (Google Apps Script backend):
       se refresca cada 30 segundos — evitar cuotas de Apps Script.
   · No refresca si hay un modal abierto o el usuario está
       escribiendo en un campo de formulario.
   · El indicador "En vivo" en el header muestra el estado.
   ============================================================ */

const REFRESH_INTERVAL_PORTAL  =  5 * 1000;  // 5 s — localStorage
const REFRESH_INTERVAL_CALENDAR = 30 * 1000;  // 30 s — Apps Script

let _livePortalTimer   = null;
let _liveCalendarTimer = null;
let _lastCalRefresh    = 0;

function isModalOpen() {
  // Check both portal modals and v49 calendar modals
  const portalModal = document.getElementById('active-modal');
  const calModals   = document.querySelectorAll('.modal-overlay.open');
  return !!portalModal || calModals.length > 0;
}

function isUserTyping() {
  const el = document.activeElement;
  if (!el) return false;
  return ['INPUT','TEXTAREA','SELECT'].includes(el.tagName);
}

function setLiveStatus(status) {
  const dot = document.getElementById('live-indicator');
  if (!dot) return;
  dot.className = 'live-dot' + (status === 'syncing' ? ' syncing' : status === 'offline' ? ' offline' : '');
  const msgs = {
    live:    'En vivo',
    syncing: 'Sincronizando…',
    offline: 'Sin conexión',
  };
  dot.textContent = msgs[status] || 'En vivo';
}

/* Silent portal refresh — secciones que usan localStorage */
function silentRefreshPortal() {
  if (isModalOpen() || isUserTyping()) return;

  const active = document.querySelector('.section.active');
  if (!active) return;
  const id = active.id.replace('section-', '');

  try {
    if (id === 'revisiones')    renderRevisiones();
    if (id === 'solicitudes')   renderSolicitudes();
    if (id === 'panel-manager') renderPanelManager();
    if (id === 'equipo')        renderEquipo();
    if (id === 'dashboard')     renderDashboard();
    if (id === 'reportes')      renderReportes();
  } catch(e) {}
}

/* Silent calendar refresh — llama al backend de Apps Script */
async function silentRefreshCalendar() {
  if (isModalOpen() || isUserTyping()) return;
  if (!cal49Initialized) return;  // Calendario aún no abierto

  const now = Date.now();
  if (now - _lastCalRefresh < REFRESH_INTERVAL_CALENDAR) return;
  _lastCalRefresh = now;

  if (!CAL49_WEB_APP_URL) return;

  setLiveStatus('syncing');

  try {
    const url  = CAL49_WEB_APP_URL + '?action=getAll&t=' + now;
    const text = await fetch(url, { method:'GET', redirect:'follow', cache:'no-cache' })
                       .then(r => r.text());

    let data;
    try { data = JSON.parse(text); }
    catch(e) {
      const m = text.match(/\{[\s\S]*\}/);
      if (m) data = JSON.parse(m[0]);
      else throw new Error('invalid json');
    }

    if (data?.ok) {
      const prev = cal49Eventos.length;
      cal49Eventos = data.eventos || data.cal49Eventos || [];

      // Only re-render if data actually changed
      if (JSON.stringify(cal49Eventos).length !== _lastCalHash) {
        _lastCalHash = JSON.stringify(cal49Eventos).length;
        try { cal49RefreshCalendar(); } catch(e) {}
        try { cal49UpdateSidebar();   } catch(e) {}

        // If dashboard is visible, update its calendar-sourced stats
        const active = document.querySelector('.section.active');
        if (active?.id === 'section-dashboard') renderDashboard();

        // Subtle badge if new events arrived
        if (cal49Eventos.length !== prev) {
          const diff = cal49Eventos.length - prev;
          if (diff > 0) showToast(`📅 +${diff} nueva${diff>1?'s':''} actividad${diff>1?'es':''} en el calendario`, 'default');
        }
      }
    }
    setLiveStatus('live');
  } catch(e) {
    // CORS failure — try JSONP silently
    try {
      const jsonpText = await new Promise((res, rej) => {
        const cb = '_sr' + Date.now();
        const s  = document.createElement('script');
        const t  = setTimeout(() => { delete window[cb]; document.body.contains(s) && document.body.removeChild(s); rej(); }, 10000);
        window[cb] = d => { clearTimeout(t); delete window[cb]; document.body.contains(s) && document.body.removeChild(s); res(JSON.stringify(d)); };
        s.src = CAL49_WEB_APP_URL + '?action=getAll&t=' + Date.now() + '&callback=' + cb;
        s.onerror = () => { clearTimeout(t); rej(); };
        document.body.appendChild(s);
      });
      const data = JSON.parse(jsonpText);
      if (data?.ok) {
        cal49Eventos = data.eventos || data.cal49Eventos || [];
        try { cal49RefreshCalendar(); } catch(e2) {}
        try { cal49UpdateSidebar();   } catch(e2) {}
      }
      setLiveStatus('live');
    } catch(e2) {
      setLiveStatus('offline');
    }
  }
}

