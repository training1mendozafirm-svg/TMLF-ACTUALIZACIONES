      justify-content: center; gap: 6px;
    }
#cal-v49 .view-tab.active {
      background: white; color: var(--text-1);
      box-shadow: 0 1px 4px rgba(0,0,0,.1);
    }
#cal-v49 .view-tab.active.el { color: #6366f1; }

    /* ── E-Learning Panel ── */
#cal-v49 #elPanel { display: none; }
