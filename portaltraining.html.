  const tryJsonp = (u) => new Promise((resolve, reject) => {
    const cbName = '_cb' + Date.now();
    const script = document.createElement('script');
    const timer  = setTimeout(() => {
      delete window[cbName];
      if (document.body.contains(script)) document.body.removeChild(script);
      reject(new Error('timeout'));
    }, 15000);
    window[cbName] = (data) => {
      clearTimeout(timer);
      delete window[cbName];
      if (document.body.contains(script)) document.body.removeChild(script);
      resolve(JSON.stringify(data));
    };
    script.src = u + '&callback=' + cbName;
    script.onerror = () => {
      clearTimeout(timer);
      if (document.body.contains(script)) document.body.removeChild(script);
      reject(new Error('script error'));
    };
    document.body.appendChild(script);
  });

  // Intentar fetch cors, luego JSONP
  try { text = await fetch(url, { method:'GET', redirect:'follow', cache:'no-cache' }).then(r => r.text()); }
  catch(e) {
    try { text = await tryJsonp(url); }
    catch(e2) { text = null; }
  }

  if (!text) {
    // Sin conexión — mantener datos en memoria y seguir mostrando
    backendActivo = false;
    cal49RefreshCalendar();
    cal49UpdateSidebar();
    return;
  }

  try {
    let data;
    try {
      data = JSON.parse(text);
    } catch(e) {
      const match = text.match(/\{[\s\S]*\}/);
      if (match) data = JSON.parse(match[0]);
      else throw new Error('Respuesta no es JSON válido');
    }
    if (data.ok) {
      // Apps Script returns { ok, eventos } — "eventos" is the original field name
      cal49Eventos = data.eventos || data.cal49Eventos || [];
      cal49RefreshCalendar();
      cal49UpdateSidebar();
      calV49ShowToast('✓ ' + cal49Eventos.length + ' actividades cargadas', 'success');
    } else {
      throw new Error(data.error || 'Respuesta inválida');
    }
  } catch(err) {
    console.error('Error procesando respuesta:', err);
    calV49ShowToast('⚠️ Error al procesar datos: ' + err.message, 'warn');
    backendActivo = false;
    cal49Eventos = [];
    cal49RefreshCalendar();
    cal49UpdateSidebar();
  }
}

// ── Guardar / editar / eliminar ────────────────────────────
// Enviamos JSON plano en el parámetro "data" (más confiable que base64)
// Con no-cors el request llega al Apps Script sin bloqueo CORS
// 2.5s después recargamos desde Sheets para confirmar escritura
async function cal49ApiPost(body) {
  if (!CAL49_WEB_APP_URL) return;
  try {
    const jsonStr = JSON.stringify(body);
    const url = CAL49_WEB_APP_URL + '?data=' + encodeURIComponent(jsonStr) + '&t=' + Date.now();
    await fetch(url, {
      method: 'GET',
      mode: 'no-cors',
      redirect: 'follow',
      cache: 'no-cache'
    });
    // Recargar desde Sheets para confirmar que se guardó
    setTimeout(() => cal49CargarEventos(), 2500);
  } catch(err) {
    console.error('cal49ApiPost error:', err);
    calV49ShowToast('⚠️ No se pudo sincronizar con la base de datos', 'warn');
  }
}

function calV49HoyOffset(days) {
  const d = new Date();
  d.setDate(d.getDate() + days);
  return d.toISOString().slice(0, 10);
}

function calV49GenId() {
  return Date.now().toString(36) + Math.random().toString(36).slice(2);
}

/* =========================================================
   FILTROS ACTIVOS
========================================================= */
let filtros = { trainer: '', tipo: '', estatus: '', modalidad: '' };

function eventosFiltrados() {
  return cal49Eventos.filter(ev => {
    if (filtros.trainer && ev.trainer !== filtros.trainer) return false;
    if (filtros.tipo && ev.tipoActividad !== filtros.tipo) return false;
    if (filtros.estatus && ev.estatus !== filtros.estatus) return false;
    if (filtros.modalidad && ev.modalidad !== filtros.modalidad) return false;
    return true;
  });
}

/* =========================================================
   FULLCALENDAR
========================================================= */
let cal49FC;

function buildFCEvents(list) {
  return list.filter(ev => !CAL49_TIPOS_ESPECIALES.includes(ev.tipoActividad)).map(ev => {
    // Detectar si es evento de día completo (sin hora 'T') o multi-día
    const isAllDay = !ev.start.includes('T');
    let endDate = ev.end || null;

    // Para cal49Eventos allday multi-día: FullCalendar usa end exclusivo,
    // si la fecha fin es igual a inicio la ignoramos; si no, sumamos 1 día
    if (isAllDay && endDate && endDate !== ev.start && !endDate.includes('T')) {
      // Sumar 1 día para que FullCalendar incluya el último día en el bloque
      const d = new Date(endDate + 'T00:00:00');
      d.setDate(d.getDate() + 1);
      endDate = d.toISOString().slice(0, 10);
    }

    return {
      id: ev.id,
      title: ev.title,
      start: ev.start,
      end: endDate,
      allDay: isAllDay,
      backgroundColor: 'transparent',
      borderColor: 'transparent',
      textColor: '#fff',
      classNames: ['ev-prio-' + (ev.prioridad || 'media').toLowerCase()],
      extendedProps: { ...ev }
    };
  });
}

// Calcula duración legible entre dos fechas/strings
function calcDuracion(ev) {
  if (!ev.start) return null;
  const isAllDay = !ev.start.includes('T');
  if (isAllDay) {
    if (!ev.end || ev.end === ev.start) return '1 día';
    const ms = calV49ParseLocal(ev.end) - calV49ParseLocal(ev.start);
    const days = Math.round(ms / 86400000) + 1;
    return days + (days === 1 ? ' día' : ' días');
  } else {
    if (!ev.end || !ev.end.includes('T')) return null;
    const ms = calV49ParseLocal(ev.end) - calV49ParseLocal(ev.start);
    const mins = Math.round(ms / 60000);
    if (mins < 60) return mins + ' min';
    const hrs = (mins / 60).toFixed(1).replace('.0','');
    return hrs + ' h';
  }
}

