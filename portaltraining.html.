  if (!el) return;

  elCalendar = new FullCalendar.Calendar(el, {
    locale: 'es',
    initialView: 'dayGridMonth',
    headerToolbar: {
      left: 'prev,next today',
      center: 'title',
      right: 'dayGridMonth,timeGridWeek'
    },
    buttonText: { today:'Hoy', month:'Mes', week:'Semana' },
    height: 'parent',
    aspectRatio: 1.5,
    expandRows: true,
    eventClick: function(info) {
      openElModal(info.event.id);
    },
    dateClick: function(info) {
      openElModal();
      setTimeout(() => {
        document.getElementById('el-form-fecha').value = info.dateStr;
      }, 50);
    }
  });
  elCalendar.render();
  setTimeout(() => { try { elCalendar.updateSize(); } catch(e){} }, 100);
}

function renderElCalendar() {
  if (!elCalendar) return;
  const fTrainer = document.getElementById('el-f-trainer')?.value || '';
  const fEstatus = document.getElementById('el-f-estatus')?.value || '';

  elCalendar.removeAllEvents();

  const ESTATUS_COLOR = {
    'Pendiente':   '#f59e0b',
    'En revisión': '#3b82f6',
    'Completado':  '#10b981',
    'Cancelado':   '#ef4444',
  };

  elSesiones
    .filter(s => (!fTrainer || s.trainer === fTrainer) && (!fEstatus || s.estatus === fEstatus))
    .forEach(s => {
      const color = ESTATUS_COLOR[s.estatus] || '#6366f1';
      elCalendar.addEvent({
        id:    s.id,
        title: '📚 ' + s.title + (s.trainer ? ' · ' + s.trainer : ''),
        start: s.start,
        end:   s.end || s.start,
        backgroundColor: color,
        borderColor:     color,
        textColor:       '#fff',
        extendedProps:   { sesion: s }
      });
    });
}

