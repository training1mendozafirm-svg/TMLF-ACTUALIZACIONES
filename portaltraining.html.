async function cargarDiTickets() {
  if (!CAL49_WEB_APP_URL) { renderDiPipeline(); return; }
  const url = CAL49_WEB_APP_URL + '?action=getAll&sheet=' + DI_SHEET + '&t=' + Date.now();
  try {
    let text;
    try {
      const r = await fetch(url, { method:'GET', redirect:'follow', mode:'cors', cache:'no-cache' });
      text = await r.text();
    } catch(e) {
      text = await new Promise((res, rej) => {
        const cb = '_dicb' + Date.now();
        const s  = document.createElement('script');
        const t  = setTimeout(() => { delete window[cb]; if(document.body.contains(s)) document.body.removeChild(s); rej(); }, 10000);
        window[cb] = d => { clearTimeout(t); delete window[cb]; if(document.body.contains(s)) document.body.removeChild(s); res(JSON.stringify(d)); };
        s.src = url + '&callback=' + cb;
        s.onerror = () => { clearTimeout(t); rej(); };
        document.body.appendChild(s);
      });
    }
    let data;
    try { data = JSON.parse(text); } catch(e) { const m = text.match(/\{[\s\S]*\}/); if(m) data = JSON.parse(m[0]); }
    if (data?.ok) diTickets = (data.diTickets || data.cal49Eventos || []).map(t => ({
      ...t,
      avances: t.avances ? (typeof t.avances === 'string' ? JSON.parse(t.avances) : t.avances) : []
    }));
  } catch(e) { /* sin backend aún */ }
  renderDiPipeline();
}

