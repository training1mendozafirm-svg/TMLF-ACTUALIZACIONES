function updateDiasOff() {
  const hoy = new Date(); hoy.setHours(0,0,0,0);
  const hace7 = new Date(hoy.getTime() - 7 * 86400000);

  const offs = cal49Eventos
    .filter(ev => ev.tipoActividad === 'Día OFF')
    .filter(ev => new Date((ev.end || ev.start) + 'T23:59:59') >= hace7)
    .sort((a,b) => new Date(a.start) - new Date(b.start))
    .slice(0, 8);

  const list = document.getElementById('offList');
  if (!offs.length) {
    list.innerHTML = '<div style="font-size:12px;color:var(--text-3);padding:4px">Sin días OFF registrados.</div>';
    return;
  }

  list.innerHTML = offs.map(ev => {
    const ini = calV49ParseLocal(ev.start);
    const fin = calV49ParseLocal(ev.end || ev.start);
    const enCurso = ini <= hoy && fin >= hoy;
    const esFuturo = ini > hoy;
    const fmtD = d => d.toLocaleDateString('es-MX', { day:'numeric', month:'short' });
    const rango = ev.start === ev.end ? fmtD(ini) : fmtD(ini) + ' – ' + fmtD(fin);
    const esEquipo = ev.trainer === 'Equipo';
    const quien = esEquipo ? '👥 Todo el equipo' : '👤 ' + ev.trainer;
    return `<div class="off-item${enCurso ? ' hoy' : ''}" onclick="cal49OpenDetailById('${ev.id}')">
      <div style="font-size:16px">🚫</div>
      <div style="flex:1;min-width:0">
        <div class="off-name">${ev.descripcion || ev.title}</div>
        <div class="off-dates">${rango} · ${quien}</div>
      </div>
      ${enCurso ? '<span class="off-badge">HOY</span>' : ''}
      ${esFuturo ? '<span class="off-badge" style="background:#0ea5e9">PRÓXIMO</span>' : ''}
    </div>`;
  }).join('');
}

function buildBannerEvents() {
  const hoy = new Date();
  const banners = [];

  cal49Eventos.filter(ev => ev.tipoActividad === 'Vacaciones').forEach(ev => {
    // Calcular end exclusivo para FC
    let endFC = ev.end || ev.start;
    const d = new Date(endFC + 'T00:00:00');
    d.setDate(d.getDate() + 1);
    endFC = d.toISOString().slice(0,10);

    // Un solo banner visible por vacaciones
    banners.push({
      id: 'vis-vac-' + ev.id,
      title: '🏖️ ' + ev.trainer + ' – Vacaciones',
      start: ev.start,
      end: endFC,
      allDay: true,
      backgroundColor: '#f59e0b',
      borderColor: '#d97706',
      textColor: '#78350f',
      classNames: ['fc-banner-vac'],
      extendedProps: { esBanner: true, tipoEspecial: 'Vacaciones', trainer: ev.trainer }
    });
  });

  // Cumpleaños — mostrar solo este año y el próximo
  cal49Eventos.filter(ev => ev.tipoActividad === 'Cumpleaños').forEach(ev => {
    const orig = calV49ParseLocal(ev.start);
    [0, 1].forEach(offset => {
      const fecha = new Date(hoy.getFullYear() + offset, orig.getMonth(), orig.getDate());
      const fechaStr = fecha.toISOString().slice(0,10);
      const endStr = new Date(fecha.getTime() + 86400000).toISOString().slice(0,10);
      banners.push({
        id: 'vis-bday-' + ev.id + '-' + offset,
        title: '🎂 ' + ev.trainer,
        start: fechaStr,
        end: endStr,
        allDay: true,
        backgroundColor: '#ec4899',
        borderColor: '#db2777',
        textColor: '#fff',
        classNames: ['fc-banner-bday'],
        extendedProps: { esBanner: true, tipoEspecial: 'Cumpleaños', trainer: ev.trainer }
      });
    });
  });

  // Días OFF — franja gris rayada + banner visible
  cal49Eventos.filter(ev => ev.tipoActividad === 'Día OFF').forEach(ev => {
    let endFC = ev.end || ev.start;
    const d = new Date(endFC + 'T00:00:00');
    d.setDate(d.getDate() + 1);
    endFC = d.toISOString().slice(0,10);

    // Fondo rayado semitransparente
    banners.push({
      id: 'bg-off-' + ev.id,
      start: ev.start, end: endFC,
      allDay: true, display: 'background',
      backgroundColor: 'rgba(148,163,184,.18)',
      borderColor: 'transparent',
      extendedProps: { esBanner: true }
    });
    // Banner visible
    const quien = ev.trainer === 'Equipo' ? '' : ' – ' + ev.trainer;
    banners.push({
      id: 'vis-off-' + ev.id,
      title: '🚫 ' + (ev.descripcion || 'Día OFF') + quien,
      start: ev.start, end: endFC,
      allDay: true,
      backgroundColor: '#64748b',
      borderColor: '#475569',
      textColor: '#fff',
      classNames: ['fc-banner-off'],
      extendedProps: { esBanner: true, tipoEspecial: 'Día OFF', realId: ev.id }
    });
  });

  return banners;
}


function cal49RefreshCalendar() {
  cal49FC.removeAllEvents();
  cal49FC.addEventSource(buildFCEvents(eventosFiltrados()));
  cal49FC.addEventSource(buildBannerEvents());
  cal49UpdateSidebar();
}

