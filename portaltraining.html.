function renderUsuarios() {
  const users     = getUsers() || [];
  const search    = document.getElementById('usr-search')?.value.toLowerCase() || '';
  const rolFilter = document.getElementById('usr-filter-rol')?.value || '';
  const estado    = document.getElementById('usr-filter-estado')?.value || '';

  const filtered = users.filter(u => {
    if (search    && !u.nombre.toLowerCase().includes(search) && !u.username.toLowerCase().includes(search)) return false;
    if (rolFilter && u.rol !== rolFilter) return false;
    if (estado === 'activo'   && !u.activo) return false;
    if (estado === 'inactivo' &&  u.activo) return false;
    return true;
  });

  // KPIs
  document.getElementById('usr-kpi-activos').textContent  = users.filter(u=>u.activo).length;
  document.getElementById('usr-kpi-inactivos').textContent= users.filter(u=>!u.activo).length;
  document.getElementById('usr-kpi-trainers').textContent  = users.filter(u=>u.rol==='trainer').length;
  document.getElementById('usr-kpi-roles').textContent     = users.filter(u=>u.rol!=='trainer').length;

  const currentSession = getSession();
  document.getElementById('usuarios-table-body').innerHTML = filtered.map(u => {
