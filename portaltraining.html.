function initCalV49() {
  if (cal49Initialized) {
    // Already initialized — just resize
    try { cal49FC && cal49FC.updateSize(); } catch(e){}
    return;
  }
  cal49Initialized = true;

  const calendarEl = document.getElementById('cal49FC');

  cal49FC = new FullCalendar.Calendar(calendarEl, {
    initialView: 'dayGridMonth',
    height: '100%',
    locale: 'es',
    firstDay: 1,
    nowIndicator: true,
    headerToolbar: {
      left: 'prev,next today',
      center: 'title',
      right: 'dayGridMonth,timeGridWeek,timeGridDay'
    },
    buttonText: { today: 'Hoy', month: 'Mes', week: 'Semana', day: 'Día' },
    eventTimeFormat: { hour: '2-digit', minute: '2-digit', hour12: false },

    /* ── eventContent: TRAINER = color de fondo · PRIORIDAD = dot indicador ── */
    eventContent: function(arg) {
      const p       = arg.event.extendedProps;
      const icon    = CAL49_TIPOS_ICON[p.tipoActividad] || '📌';
      const bgColor = cal49TrainerColor(p.trainer);          // fondo principal
      const prio    = (p.prioridad || 'Media').toLowerCase();
      const dur     = calcDuracion(p);

      // Dot de prioridad — pequeño, solo indicador
      const PRIO_DOT = { alta: '🔴', media: '🟡', baja: '🟢' };
      const PRIO_LABEL = { alta: 'Alta', media: 'Media', baja: 'Baja' };
      const prioDot   = PRIO_DOT[prio]   || '🟡';
      const prioLabel = PRIO_LABEL[prio] || 'Media';

      // Horario
      let scheduleStr = '';
      if (p.start && p.start.includes('T')) {
        const tS = p.start.slice(11, 16);
        const tE = p.end && p.end.includes('T') ? p.end.slice(11, 16) : null;
        scheduleStr = tE ? `${tS} – ${tE}` : tS;
      } else if (p.end && p.end !== p.start) {
        const ds  = new Date(p.start + 'T00:00:00');
        const de  = new Date(p.end   + 'T00:00:00');
        de.setDate(de.getDate() - 1);
        const fmt = d => d.toLocaleDateString('es-MX', { month: 'short', day: 'numeric' });
        scheduleStr = `${fmt(ds)} – ${fmt(de)}`;
      } else {
        scheduleStr = 'Todo el día';
      }

      // Tooltip
      const tooltipHTML = `
        <div style="font-weight:700;font-size:12.5px;margin-bottom:5px">${icon} ${p.title || arg.event.title}</div>
        <div style="opacity:.85;font-size:11px;margin-bottom:2px">👤 ${p.trainer || '—'}${p.trainer2 ? ' + ' + p.trainer2 : ''} · ${p.tipoActividad || '—'}</div>
        <div style="opacity:.85;font-size:11px;margin-bottom:2px">🕐 ${scheduleStr}${dur ? ' · ' + dur : ''}</div>
        <div style="opacity:.85;font-size:11px;margin-bottom:2px">📍 ${p.sala || '—'} · ${p.modalidad || '—'}</div>
        <div style="margin-top:5px;font-size:11px">${prioDot} Prioridad ${prioLabel}</div>
        ${p.descripcion ? `<div style="opacity:.7;font-size:10.5px;margin-top:4px;font-style:italic;border-top:1px solid rgba(255,255,255,.15);padding-top:4px">"${p.descripcion.slice(0,90)}${p.descripcion.length>90?'…':''}"</div>` : ''}
      `;

      // ── DOM ─────────────────────────────────────────────────
      const wrapper = document.createElement('div');
      wrapper.style.cssText = `position:relative;width:100%;height:100%;`;

      // Bloque principal — color del TRAINER domina el fondo
      const inner = document.createElement('div');
      inner.style.cssText = `
        display:flex;align-items:stretch;
        width:100%;height:100%;min-height:0;
        border-radius:6px;
        overflow:hidden;
        background:${bgColor};
        border:1.5px solid rgba(0,0,0,.18);
        box-shadow:0 1px 3px rgba(0,0,0,.20);
      `;

      // Texto — toda la anchura
      const body = document.createElement('div');
      body.style.cssText = `
        flex:1;min-width:0;
        padding:4px 6px;
        display:flex;flex-direction:column;justify-content:center;gap:1px;
      `;

      // Línea 1 — dot prioridad + título
      const titleLine = document.createElement('div');
      titleLine.style.cssText = `
        font-weight:600;font-size:11.5px;color:#fff;
        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
        line-height:1.35;
      `;
      titleLine.textContent = `${prioDot} ${icon} ${arg.event.title}`;

      // Línea 2 — trainer
      const trainerLine = document.createElement('div');
      trainerLine.style.cssText = `
        font-size:10px;font-weight:600;color:rgba(255,255,255,.88);
        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
        line-height:1.2;
      `;
      trainerLine.textContent = p.trainer2 ? `👤 ${p.trainer} + ${p.trainer2}` : `👤 ${p.trainer || '—'}`;

      // Línea 3 — horario
      const timeLine = document.createElement('div');
      timeLine.style.cssText = `
        font-size:10px;font-weight:600;color:rgba(255,255,255,.78);
        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
        line-height:1.2;
      `;
      timeLine.textContent = `🕐 ${scheduleStr}`;

      body.appendChild(titleLine);
      body.appendChild(trainerLine);
      body.appendChild(timeLine);
      inner.appendChild(body);

      // Tooltip
      const tooltip = document.createElement('div');
      tooltip.className = 'ev-tooltip';
      tooltip.innerHTML = tooltipHTML;

      wrapper.appendChild(inner);
      wrapper.appendChild(tooltip);

      return { domNodes: [wrapper] };
    },

    eventClick: function(info) {
      const id = info.event.id;
      // Banners de vacaciones/cumpleaños tienen id con prefijo vis-vac- o vis-bday-
      if (id.startsWith('vis-vac-')) {
        const realId = id.replace('vis-vac-', '').replace(/-\d+$/, '');
        cal49OpenDetailById(realId);
      } else if (id.startsWith('vis-bday-')) {
        const realId = id.replace('vis-bday-', '').replace(/-\d+$/, '');
        cal49OpenDetailById(realId);
      } else if (id.startsWith('vis-off-')) {
        const realId = id.replace('vis-off-', '');
        cal49OpenDetailById(realId);
      } else {
        cal49OpenDetailById(id);
      }
    },

    dateClick: cal49HandleDateClick,

    /* Drag, resize y selección de rango */
    editable: true,
    selectable: true,
    selectMirror: true,

    // Seleccionar rango de fechas abre el form con las fechas prellenadas
    select: function(info) {
      cal49ResetForm();
      document.getElementById('f-form-date').value = info.startStr.slice(0, 10);
      const endD = new Date(info.end);
      endD.setDate(endD.getDate() - 1); // FC end es exclusivo
      const endStr = endD.toISOString().slice(0,10);
      if (endStr !== info.startStr.slice(0,10)) {
        document.getElementById('f-form-date-end').value = endStr;
        document.getElementById('dateRangeHint').style.display = 'block';
      }
      document.getElementById('f-form-allday').checked = info.allDay;
      document.getElementById('timeRow').style.display = info.allDay ? 'none' : 'grid';
      if (!info.allDay && info.startStr.includes('T')) {
        document.getElementById('f-form-start').value = info.startStr.slice(11,16);
        if (info.endStr && info.endStr.includes('T'))
          document.getElementById('f-form-end').value = info.endStr.slice(11,16);
      }
      calV49OpenModal('formModal');
      cal49FC.unselect();
    },

    eventDrop: function(info) {
      const ev = cal49Eventos.find(e => e.id === info.event.id);
      if (!ev) return;
      ev.start = info.event.startStr || info.event.start.toISOString().slice(0,10);
      ev.end = info.event.endStr || (info.event.end ? info.event.end.toISOString().slice(0,10) : null);
      // Si allDay no tiene hora
      if (info.event.allDay && ev.start.includes('T')) ev.start = ev.start.slice(0,10);
      if (info.event.allDay && ev.end && ev.end.includes('T')) ev.end = ev.end.slice(0,10);
      cal49ApiPost({ action: 'update', evento: ev });
      calV49ShowToast('✓ Actividad movida');
      cal49UpdateSidebar();
    },

    eventResize: function(info) {
      const ev = cal49Eventos.find(e => e.id === info.event.id);
      if (!ev) return;
      ev.start = info.event.startStr || ev.start;
      ev.end = info.event.endStr || (info.event.end ? info.event.end.toISOString().slice(0,10) : null);
      if (info.event.allDay && ev.end && ev.end.includes('T')) ev.end = ev.end.slice(0,10);
      cal49ApiPost({ action: 'update', evento: ev });
      calV49ShowToast('✓ Duración actualizada');
      cal49UpdateSidebar();
    }
  });


  cal49SetupAlldayToggle();

  // Forzar vista Calendario al inicio
  document.getElementById('calPanel').style.display = 'flex';
  document.getElementById('elPanel').style.display  = 'none';
  document.getElementById('tab-cal').classList.add('active');
  document.getElementById('tab-el').classList.remove('active');
  document.getElementById('topbar-sub-text').textContent = 'Coordinación del equipo de capacitación';
  document.getElementById('openFormBtnLabel').textContent = 'Agregar actividad';
  document.getElementById('openFormBtn').style.background = '';
  document.getElementById('openFormBtn').style.borderColor = '';
  document.getElementById('todayBtn').style.display = '';
  vistaActiva = 'cal';

  // Renderizar FullCalendar tras dos frames para asegurar dimensiones
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      cal49FC.render();
      setTimeout(() => { try { cal49FC.updateSize(); } catch(e){} }, 100);
      setTimeout(() => { try { cal49FC.updateSize(); } catch(e){} }, 500);
    });
  });

  cal49CargarEventos();
  cal49UpdateSidebar();

  /* ──────────────────────────────────────────────────────
     BACKEND CONNECTION POINT
     ──────────────────────────────────────────────────────
     Para conectar con Google Sheets / Apps Script:

     const CAL49_WEB_APP_URL = "https://script.google.com/macros/s/TU_ID/exec";

     // CARGAR EVENTOS AL INICIO:
     async function loadFromBackend() {
       const res = await fetch(CAL49_WEB_APP_URL + '?action=getAll&t=' + Date.now());
       const data = await res.json();
       cal49Eventos = data.eventos; // Apps Script devuelve { ok, eventos: [...] }
       cal49RefreshCalendar();
     }
     loadFromBackend();

     // GUARDAR: en cal49SaveEvento(), reemplaza el push local
     //   con: await fetch(CAL49_WEB_APP_URL, { method:'POST', body: JSON.stringify({action:'create', evento:ev}) });

     // EDITAR: en editEventBtn,
     //   con: await fetch(CAL49_WEB_APP_URL, { method:'POST', body: JSON.stringify({action:'update', evento:ev}) });

     // ELIMINAR: en deleteEventBtn,
     //   con: await fetch(CAL49_WEB_APP_URL, { method:'POST', body: JSON.stringify({action:'delete', id:currentDetailId}) });
  ─────────────────────────────────────────────────── */
} // end initCalV49()


</script>
</body>
