function updateKPIs() {
  const now = new Date();
  const mesAct = now.getMonth();
  const anio = now.getFullYear();
  const semana = new Date(now.getTime() + 7 * 86400000);

  const delMes = eventosFiltrados().filter(ev => {
    const d = calV49ParseLocal(ev.start);
    return d.getMonth() === mesAct && d.getFullYear() === anio;
  });
  const trainings = delMes.filter(ev =>
    (ev.tipoActividad === 'Training teórico' || ev.tipoActividad === 'Training práctico')
    && !CAL49_TIPOS_ESPECIALES.includes(ev.tipoActividad)
  );
  const pendientes = eventosFiltrados().filter(ev =>
    ev.estatus === 'Planeado' || ev.estatus === 'Confirmado'
  );
  const proximas = eventosFiltrados().filter(ev => {
    const d = calV49ParseLocal(ev.start);
    return d >= now && d <= semana;
  });

  document.getElementById('kpi-total').textContent = delMes.length;
  document.getElementById('kpi-trainings').textContent = trainings.length;
  document.getElementById('kpi-pendientes').textContent = pendientes.length;
  document.getElementById('kpi-proximas').textContent = proximas.length;
}

function updateWorkload() {
  const counts = {};
  const evs = eventosFiltrados().filter(ev => !CAL49_TIPOS_ESPECIALES.includes(ev.tipoActividad));
  const total = evs.length || 1;
  evs.forEach(ev => {
    counts[ev.trainer] = (counts[ev.trainer] || 0) + 1;
  });
  const list = document.getElementById('workloadList');
  list.innerHTML = '';
  Object.keys(CAL49_TRAINERS).forEach(name => {
    const c = counts[name] || 0;
    const pct = Math.round((c / total) * 100);
    const color = cal49TrainerColor(name);
    list.innerHTML += `
      <div style="display:flex;align-items:center;gap:7px;padding:4px 4px 2px;">
        <div style="width:10px;height:10px;border-radius:50%;background:${color};flex-shrink:0"></div>
        <span style="font-size:12.5px;font-weight:600;flex:1;color:var(--text-2)">${name}</span>
        <span style="font-size:11px;font-weight:700;font-family:'DM Mono',monospace;color:${color}">${c}</span>
      </div>
      <div style="padding:0 4px 5px 21px">
        <div style="height:3px;border-radius:2px;background:var(--border);overflow:hidden">
          <div style="height:100%;width:${pct}%;background:${color};border-radius:2px;transition:width .4s"></div>
        </div>
      </div>`;
  });
}

function updateLegend() {
  const list = document.getElementById('legendList');
  list.innerHTML = '';
  Object.entries(CAL49_TRAINERS).forEach(([name, color]) => {
    list.innerHTML += `
      <div class="legend-item">
        <div class="legend-swatch" style="background:${color}"></div>
        <span>${name}</span>
      </div>`;
  });
}

function updateUpcoming() {
  const now = new Date();
  const semana = new Date(now.getTime() + 7 * 86400000);
  const prox = eventosFiltrados()
    .filter(ev => { const d = calV49ParseLocal(ev.start); return d >= now && d <= semana; })
    .sort((a, b) => calV49ParseLocal(a.start) - calV49ParseLocal(b.start))
    .slice(0, 5);

  const list = document.getElementById('upcomingList');
  if (!prox.length) {
    list.innerHTML = '<div style="font-size:12.5px;color:var(--text-3);padding:8px 4px">Sin actividades en los próximos 7 días.</div>';
    return;
  }
  list.innerHTML = prox.map(ev => {
    const d = calV49ParseLocal(ev.start);
    const fecha = d.toLocaleDateString('es-MX', { weekday: 'short', day: 'numeric', month: 'short' });
    const hora = d.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit', hour12: false });
    const color = cal49TrainerColor(ev.trainer);
    return `<div class="upcoming-item" style="border-left-color:${color}" onclick="cal49OpenDetailById('${ev.id}')">
      <div class="upcoming-title">${ev.title}</div>
      <div class="upcoming-meta">${fecha} · ${hora} · ${ev.sala || '—'}</div>
      <div class="upcoming-trainer" style="color:${color}">${ev.trainer} · ${ev.tipoActividad}</div>
    </div>`;
  }).join('');
}

